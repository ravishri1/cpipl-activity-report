# eSSL Biometric Sync Agent Configuration
# ==========================================
# Copy this file to .env and edit the values.
# The agent reads this automatically on startup.

# ─── Mode ─────────────────────────────────────────
# multi = Auto-discover all devices from HR API (recommended)
# single = Sync only one device (legacy)
MODE=multi

# ─── Cloud HR App ─────────────────────────────────
HR_API_URL=https://eod.colorpapers.in
HR_AGENT_KEY=biometric-sync-key

# ─── Sync Settings ───────────────────────────────
POLL_INTERVAL_MINUTES=5
LOOKBACK_DAYS=1

# ─── Single-device mode only (ignored in multi mode) ─
# ESSL_URL=http://192.168.2.222:85
# ESSL_API_PATH=/IClock/WebService.asmx
# ESSL_USER=dany
# ESSL_PASSWORD=Essl@123
# ESSL_API_KEY=11
# ESSL_COMPANY_CODE=essl
# ESSL_SERIAL=CUB7240300491
