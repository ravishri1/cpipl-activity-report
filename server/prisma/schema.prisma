generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  password           String
  role               String   @default("member") // admin, team_lead, member
  department         String   @default("General")
  isActive           Boolean  @default(true)
  googleId           String?  @unique
  importedFromGoogle Boolean  @default(false)
  totalPoints        Int      @default(0) // cached leaderboard score
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // ── HR Profile Fields ──
  employeeId         String?  @unique          // "CPIPL-001" format
  designation        String?                   // "Software Engineer"
  dateOfJoining      String?                   // "YYYY-MM-DD"
  dateOfBirth        String?                   // "YYYY-MM-DD"
  employmentType     String   @default("full_time") // full_time, part_time, contract, intern
  phone              String?
  phoneVerified      Boolean  @default(false)
  personalEmail      String?
  address            String?
  emergencyContact   String?                   // JSON: [{"name","fatherName","phone","relation"}] (2 refs)
  emergencyContact2  String?                   // JSON: {"name","fatherName","phone","relation"} (2nd ref)
  gender             String?                   // male, female, other
  bloodGroup         String?
  profilePhotoUrl    String?
  reportingManagerId Int?

  // ── Extended Profile (greytHR-style) ──
  // Personal
  maritalStatus      String?                   // single, married, divorced, widowed
  nationality        String?  @default("Indian")
  fatherName         String?
  spouseName         String?
  religion           String?
  placeOfBirth       String?
  permanentAddress   String?                   // separate from current address
  // Identity Documents
  aadhaarNumber      String?
  panNumber          String?
  passportNumber     String?
  passportExpiry     String?                   // "YYYY-MM-DD"
  drivingLicense     String?
  uanNumber          String?                   // Universal Account Number (PF)
  // Bank Details
  bankName           String?
  bankAccountNumber  String?
  bankBranch         String?
  bankIfscCode       String?
  // Employment Extended
  confirmationDate   String?                   // "YYYY-MM-DD"
  probationEndDate   String?                   // "YYYY-MM-DD"
  noticePeriodDays   Int?     @default(30)
  previousExperience Float?   @default(0)      // years
  location           String?                   // office/branch location
  grade              String?                   // pay grade / level
  shift              String?  @default("General") // shift name

  // ── Company ──
  companyId          Int?
  company            Company? @relation(fields: [companyId], references: [id])

  // ── Existing Relations ──
  reports          DailyReport[]
  reminders        Reminder[]
  googleToken      GoogleToken?
  emailActivities  EmailActivity[]
  chatActivities   ChatActivity[]
  pointLogs        PointLog[]
  thumbsUpsGiven   ThumbsUp[]    @relation("ThumbsUpGiver")
  thumbsUpsReceived ThumbsUp[]   @relation("ThumbsUpReceiver")
  appreciationsGiven    Appreciation[]      @relation("AppreciationsGiven")
  appreciationsReceived Appreciation[]      @relation("AppreciationsReceived")
  appreciationBudgets   AppreciationBudget[]

  // ── HR Relations ──
  reportingManager   User?    @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  subordinates       User[]   @relation("ReportingManager")
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  documents          EmployeeDocument[]
  educations         Education[]
  familyMembers      FamilyMember[]
  previousEmployments PreviousEmployment[]
  profileChangeLogs  ProfileChangeLog[]   @relation("ProfileChanges")
  changesLoggedBy    ProfileChangeLog[]   @relation("ChangesMadeBy")
  policyAcceptances  PolicyAcceptance[]
  salaryStructure    SalaryStructure?
  payslips           Payslip[]
  salaryRevisions    SalaryRevision[]
  salaryRevisionsBy  SalaryRevision[]   @relation("SalaryRevisionsBy")
  expenseClaims      ExpenseClaim[]
  expenseReviews     ExpenseClaim[]     @relation("ExpenseReviews")
  announcements      Announcement[]     @relation("AnnouncementAuthor")
  generatedLetters   GeneratedLetter[]
  lettersGeneratedBy GeneratedLetter[]  @relation("LetterGeneratedBy")
  assignedAssets     Asset[]            @relation("AssetAssignment")
  onboardingTasks    OnboardingChecklist[]
  separation         Separation?
  separationHandler  Separation[]       @relation("SeparationHandler")
  overtimeRequests   OvertimeRequest[]
  overtimeReviews    OvertimeRequest[]  @relation("OvertimeReviews")
  surveyResponses    SurveyResponse[]
  surveysCreated     Survey[]           @relation("SurveyCreator")
  tickets            Ticket[]
  assignedTickets    Ticket[]           @relation("TicketAssignee")
  ticketComments     TicketComment[]
  otpRequests        OtpVerification[]

  @@index([department])
  @@index([isActive])
  @@index([companyId])
  @@index([reportingManagerId])
  @@index([role])
  @@index([createdAt])
}

model DailyReport {
  id            Int      @id @default(autoincrement())
  userId        Int
  reportDate    String   // YYYY-MM-DD format for easy querying
  activities    String
  challenges    String   @default("")
  planTomorrow  String   @default("")
  totalHours    Float    @default(0)
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id])
  tasks     ReportTask[]
  thumbsUps ThumbsUp[]

  @@unique([userId, reportDate])
  @@index([reportDate])
  @@index([submittedAt])
}

model ReportTask {
  id          Int    @id @default(autoincrement())
  reportId    Int
  description String
  hours       Float  @default(0)

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Reminder {
  id           Int      @id @default(autoincrement())
  userId       Int
  reportDate   String   // YYYY-MM-DD
  reminderType String   // "first" or "escalation"
  sentAt       DateTime @default(now())
  status       String   @default("sent") // sent, acknowledged

  user User @relation(fields: [userId], references: [id])

  @@index([userId, reportDate])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model GoogleToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmailActivity {
  id             Int      @id @default(autoincrement())
  userId         Int
  activityDate   String   // YYYY-MM-DD
  emailsSent     Int      @default(0)
  emailsReceived Int      @default(0)
  fetchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model ChatActivity {
  id           Int      @id @default(autoincrement())
  userId       Int
  activityDate String   // YYYY-MM-DD
  messagesSent Int      @default(0)
  fetchedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model PointLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  date        String   // YYYY-MM-DD
  source      String   // report, calendar, task, email, chat, thumbsup
  points      Int
  description String   @default("")
  givenBy     Int?     // userId of team lead (for thumbsup only)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([date])
  @@index([source])
}

model ThumbsUp {
  id             Int      @id @default(autoincrement())
  reportId       Int
  givenByUserId  Int
  receiverUserId Int
  createdAt      DateTime @default(now())

  report   DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  givenBy  User        @relation("ThumbsUpGiver", fields: [givenByUserId], references: [id])
  receiver User        @relation("ThumbsUpReceiver", fields: [receiverUserId], references: [id])

  @@unique([reportId, givenByUserId])
  @@index([receiverUserId])
}

model Appreciation {
  id          Int      @id @default(autoincrement())
  giverId     Int
  receiverId  Int
  points      Int      @default(5)
  reason      String
  status      String   @default("normal") // normal, warned, penalized
  flagReason  String?
  createdAt   DateTime @default(now())

  giver    User @relation("AppreciationsGiven", fields: [giverId], references: [id])
  receiver User @relation("AppreciationsReceived", fields: [receiverId], references: [id])

  @@index([giverId])
  @@index([receiverId])
  @@index([createdAt])
}

model AppreciationBudget {
  id           Int    @id @default(autoincrement())
  userId       Int
  weekStart    String // YYYY-MM-DD (Monday)
  totalGiven   Int    @default(0)
  warningCount Int    @default(0)
  penaltyCount Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
}

// ═══════════════════════════════════════════════
// HR Core Models
// ═══════════════════════════════════════════════

model Attendance {
  id        Int       @id @default(autoincrement())
  userId    Int
  date      String                              // "YYYY-MM-DD"
  checkIn   DateTime?
  checkOut  DateTime?
  status    String    @default("present")       // present, absent, half_day, on_leave, holiday, weekend
  workHours Float?                              // auto-calc from checkIn/checkOut
  ipAddress String?
  notes     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
}

model LeaveType {
  id              Int      @id @default(autoincrement())
  name            String   @unique              // "Casual Leave", "Sick Leave", "Earned Leave"
  code            String   @unique              // "CL", "SL", "EL"
  defaultBalance  Float    @default(0)          // annual entitlement
  carryForward    Boolean  @default(false)
  maxCarryForward Float    @default(0)
  isActive        Boolean  @default(true)

  balances LeaveBalance[]
  requests LeaveRequest[]
}

model LeaveBalance {
  id          Int   @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  year        Int                               // 2026
  total       Float @default(0)                 // allocated
  used        Float @default(0)                 // consumed
  balance     Float @default(0)                 // remaining = total - used

  user      User      @relation(fields: [userId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([userId, leaveTypeId, year])
}

model LeaveRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  startDate   String                            // "YYYY-MM-DD"
  endDate     String                            // "YYYY-MM-DD"
  days        Float                             // computed (supports half-days: 0.5)
  reason      String
  status      String    @default("pending")     // pending, approved, rejected, cancelled
  reviewedBy  Int?                              // userId of approver
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

model Holiday {
  id         Int     @id @default(autoincrement())
  name       String                              // "Republic Day"
  date       String                              // "YYYY-MM-DD"
  year       Int
  isOptional Boolean @default(false)

  @@unique([date])
  @@index([year])
}

model Education {
  id           Int     @id @default(autoincrement())
  userId       Int
  degree       String                              // "B.Tech", "MBA", "12th"
  institution  String                              // "IIT Delhi"
  university   String?                             // "Delhi University"
  specialization String?                           // "Computer Science"
  yearOfPassing String?                            // "2020"
  percentage   String?                             // "85%" or "8.5 CGPA"

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model FamilyMember {
  id           Int     @id @default(autoincrement())
  userId       Int
  name         String
  relationship String                              // father, mother, spouse, child, sibling
  dateOfBirth  String?                             // "YYYY-MM-DD"
  occupation   String?
  phone        String?
  isDependent  Boolean @default(false)
  isNominee    Boolean @default(false)             // EPF/Gratuity nominee
  nomineeShare Float?                              // percentage share

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model PreviousEmployment {
  id           Int     @id @default(autoincrement())
  userId       Int
  company      String
  designation  String?
  fromDate     String?                             // "YYYY-MM-DD"
  toDate       String?                             // "YYYY-MM-DD"
  ctc          String?                             // last drawn CTC
  reasonForLeaving String?

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model EmployeeDocument {
  id         Int      @id @default(autoincrement())
  userId     Int
  name       String                              // "Aadhar Card"
  type       String                              // "id_proof", "address_proof", "education", "other"
  fileUrl    String                              // Vercel Blob URL
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ProfileChangeLog {
  id          Int      @id @default(autoincrement())
  userId      Int                                   // employee whose profile was changed
  changedBy   Int                                   // user who made the change
  section     String                                // "profile", "education", "family", "employment", "photo"
  field       String                                // field name or sub-record description
  oldValue    String?                               // previous value (null for new additions)
  newValue    String?                               // new value
  action      String   @default("update")           // "update", "add", "delete"
  createdAt   DateTime @default(now())

  user      User @relation("ProfileChanges", fields: [userId], references: [id])
  changedByUser User @relation("ChangesMadeBy", fields: [changedBy], references: [id])

  @@index([userId, createdAt])
  @@index([changedBy])
}

// ═══════════════════════════════════════════════
// Company Model
// ═══════════════════════════════════════════════

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  shortName String?                              // "CPIPL", "Gimmick"
  gst       String?
  state     String?
  city      String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users         User[]
  policies      Policy[]
  announcements Announcement[]
  assets           Asset[]
  shiftDefinitions ShiftDefinition[]
  surveys          Survey[]
}

// ═══════════════════════════════════════════════
// Policy Management
// ═══════════════════════════════════════════════

model Policy {
  id            Int      @id @default(autoincrement())
  title         String                                // "Work From Home Policy"
  slug          String   @unique                      // "work-from-home-policy"
  category      String   @default("general")          // general, attendance, leave, conduct, benefits, safety
  content       String                                // Full policy text (markdown/HTML)
  summary       String?                               // Brief summary for listing
  version       Int      @default(1)                  // version number
  effectiveDate String?                               // "YYYY-MM-DD"
  isActive      Boolean  @default(true)
  isMandatory   Boolean  @default(true)               // Must all employees accept?
  companyId     Int?                                   // null = applies to all companies
  createdBy     Int?                                   // admin who created it
  protectionScore Float? @default(0)                   // 0-100 score of how well policy protects company
  scoreBreakdown  String?                              // JSON: {"legal":80,"compliance":70,...}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company?           @relation(fields: [companyId], references: [id])
  sections      PolicySection[]
  acceptances   PolicyAcceptance[]
  versions      PolicyVersion[]

  @@index([category])
  @@index([isActive])
}

model PolicySection {
  id        Int     @id @default(autoincrement())
  policyId  Int
  title     String                                    // "Scope", "Eligibility", "Procedure"
  content   String                                    // Section text
  sortOrder Int     @default(0)
  isEditable Boolean @default(false)                  // HR can customize this section per employee

  policy    Policy  @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

model PolicyAcceptance {
  id         Int      @id @default(autoincrement())
  policyId   Int
  userId     Int
  version    Int      @default(1)                     // which version was accepted
  acceptedAt DateTime @default(now())
  ipAddress  String?
  remarks    String?                                  // optional employee comment

  policy     Policy @relation(fields: [policyId], references: [id])
  user       User   @relation(fields: [userId], references: [id])

  @@unique([policyId, userId, version])
  @@index([userId])
}

model PolicyVersion {
  id        Int      @id @default(autoincrement())
  policyId  Int
  version   Int
  content   String                                    // snapshot of content at this version
  changedBy Int?                                      // admin who made changes
  changeLog String?                                   // what changed
  createdAt DateTime @default(now())

  policy    Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, version])
}

// ═══════════════════════════════════════════════
// Payroll & Salary
// ═══════════════════════════════════════════════

model SalaryStructure {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  ctcAnnual            Float                          // Annual CTC
  ctcMonthly           Float                          // CTC / 12

  // Earnings
  basic                Float    @default(0)
  hra                  Float    @default(0)
  da                   Float    @default(0)           // Dearness Allowance
  specialAllowance     Float    @default(0)
  medicalAllowance     Float    @default(0)
  conveyanceAllowance  Float    @default(0)
  otherAllowance       Float    @default(0)
  otherAllowanceLabel  String?                        // custom label for other allowance

  // Employer Contributions (not part of net pay)
  employerPf           Float    @default(0)
  employerEsi          Float    @default(0)

  // Employee Deductions
  employeePf           Float    @default(0)
  employeeEsi          Float    @default(0)
  professionalTax      Float    @default(0)
  tds                  Float    @default(0)

  netPayMonthly        Float    @default(0)           // Gross - Deductions
  effectiveFrom        String?                        // "YYYY-MM-DD"
  notes                String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id])
}

model Payslip {
  id                   Int      @id @default(autoincrement())
  userId               Int
  month                String                          // "2026-03"
  year                 Int

  // Earnings
  basic                Float    @default(0)
  hra                  Float    @default(0)
  da                   Float    @default(0)
  specialAllowance     Float    @default(0)
  medicalAllowance     Float    @default(0)
  conveyanceAllowance  Float    @default(0)
  otherAllowance       Float    @default(0)
  otherAllowanceLabel  String?
  grossEarnings        Float    @default(0)

  // Deductions
  employeePf           Float    @default(0)
  employeeEsi          Float    @default(0)
  professionalTax      Float    @default(0)
  tds                  Float    @default(0)
  otherDeductions      Float    @default(0)
  otherDeductionsLabel String?
  totalDeductions      Float    @default(0)

  netPay               Float    @default(0)

  // Attendance
  workingDays          Int      @default(0)
  presentDays          Float    @default(0)
  lopDays              Float    @default(0)           // Loss of Pay days
  lopDeduction         Float    @default(0)

  status               String   @default("draft")     // draft, generated, published
  generatedAt          DateTime?
  publishedAt          DateTime?
  pdfUrl               String?

  createdAt            DateTime @default(now())

  user                 User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@index([month])
  @@index([status])
}

model SalaryRevision {
  id            Int      @id @default(autoincrement())
  userId        Int
  effectiveFrom String                                // "YYYY-MM-DD"
  oldCtc        Float
  newCtc        Float
  reason        String?
  revisedBy     Int                                   // admin userId
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  revisedByUser User     @relation("SalaryRevisionsBy", fields: [revisedBy], references: [id])

  @@index([userId])
}

// ═══════════════════════════════════════════════
// Expense Claims
// ═══════════════════════════════════════════════

model ExpenseClaim {
  id            Int       @id @default(autoincrement())
  userId        Int
  title         String
  category      String    @default("other")            // travel, food, medical, office, other
  amount        Float
  description   String?
  receiptUrl    String?                                // base64 or URL
  date          String                                 // "YYYY-MM-DD"
  status        String    @default("pending")          // pending, approved, rejected, paid
  reviewedBy    Int?
  reviewedAt    DateTime?
  reviewNote    String?
  paidOn        String?                                // "YYYY-MM-DD"
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  reviewer      User?     @relation("ExpenseReviews", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([date])
  @@index([category])
}

// ═══════════════════════════════════════════════
// Announcements
// ═══════════════════════════════════════════════

model Announcement {
  id            Int       @id @default(autoincrement())
  title         String
  content       String                                 // markdown/rich text
  category      String    @default("general")          // general, policy, event, birthday, anniversary
  priority      String    @default("normal")           // normal, important, urgent
  companyId     Int?                                   // null = all companies
  postedBy      Int
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  company       Company?  @relation(fields: [companyId], references: [id])
  author        User      @relation("AnnouncementAuthor", fields: [postedBy], references: [id])

  @@index([isActive])
  @@index([category])
}

// ═══════════════════════════════════════════════
// Letter Templates & Generated Letters
// ═══════════════════════════════════════════════

model LetterTemplate {
  id          Int       @id @default(autoincrement())
  name        String                                     // "Offer Letter", "Appointment Letter"
  type        String                                     // offer, appointment, salary_revision, experience, relieving, custom
  content     String                                     // HTML template with {{placeholders}}
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  generatedLetters GeneratedLetter[]
}

model GeneratedLetter {
  id            Int       @id @default(autoincrement())
  userId        Int
  templateId    Int
  letterType    String                                   // same as template.type
  content       String                                   // rendered HTML
  generatedBy   Int                                      // admin userId
  generatedAt   DateTime  @default(now())

  user          User            @relation(fields: [userId], references: [id])
  template      LetterTemplate  @relation(fields: [templateId], references: [id])
  generatedByUser User          @relation("LetterGeneratedBy", fields: [generatedBy], references: [id])

  @@index([userId])
}

// ═══════════════════════════════════════════════
// Asset Management
// ═══════════════════════════════════════════════

model Asset {
  id             Int       @id @default(autoincrement())
  name           String                                  // "Dell Laptop", "iPhone 15"
  type           String                                  // laptop, phone, simcard, mouse, charger, monitor, keyboard, headset, id_card, access_card, scanner, ac_remote, other
  serialNumber   String?
  assetTag       String?   @unique                       // "AST-001" office tracking tag
  category       String    @default("personal")          // personal (assigned to person), office (shared/office use), infrastructure
  purchaseDate   String?                                 // "YYYY-MM-DD"
  value          Float?
  warrantyExpiry String?                                 // "YYYY-MM-DD" — warranty end date
  warrantyVendor String?                                 // vendor/brand for warranty claims
  condition      String    @default("good")              // new, good, fair, damaged, non_working
  status         String    @default("available")         // available, assigned, maintenance, retired, lost
  assignedTo     Int?
  assignedDate   String?                                 // "YYYY-MM-DD"
  returnDate     String?                                 // "YYYY-MM-DD"
  notes          String?
  companyId      Int?
  location       String?                                  // "Miraroad", "Lucknow" — office location where asset is
  isMandatoryReturn Boolean @default(true)               // must return on exit (false for consumables)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assignee       User?     @relation("AssetAssignment", fields: [assignedTo], references: [id])
  company        Company?  @relation(fields: [companyId], references: [id])
  handovers      AssetHandover[]

  @@index([assignedTo])
  @@index([status])
  @@index([category])
  @@index([type])
}

// ═══════════════════════════════════════════════
// Employee Lifecycle (Onboarding & Separation)
// ═══════════════════════════════════════════════

model OnboardingChecklist {
  id           Int       @id @default(autoincrement())
  userId       Int
  task         String                                    // "Submit ID proof", "Bank account form"
  category     String    @default("hr_formalities")      // documents, it_setup, hr_formalities, training
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  dueDate      String?                                   // "YYYY-MM-DD"
  assignedTo   String?                                   // "HR", "IT", "Manager"
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isCompleted])
}

model Separation {
  id                 Int       @id @default(autoincrement())
  userId             Int       @unique
  type               String                              // resignation, termination, absconding, retirement
  requestDate        String                              // "YYYY-MM-DD"
  lastWorkingDate    String?                             // "YYYY-MM-DD"
  reason             String?
  status             String    @default("initiated")     // initiated, notice_period, fnf_pending, completed, cancelled
  noticePeriodDays   Int       @default(30)
  exitInterviewDone  Boolean   @default(false)
  exitInterviewNotes String?
  allAssetsReturned  Boolean   @default(false)           // must be true before FnF
  assetReturnNotes   String?                             // JSON: details of pending/returned assets
  fnfAmount          Float?
  fnfHoldReason      String?                             // "pending_asset_return" etc.
  fnfPaidOn          String?                             // "YYYY-MM-DD"
  processedBy        Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User     @relation(fields: [userId], references: [id])
  processor          User?    @relation("SeparationHandler", fields: [processedBy], references: [id])
}

// ═══════════════════════════════════════════════
// Shift Management
// ═══════════════════════════════════════════════

model ShiftDefinition {
  id            Int       @id @default(autoincrement())
  name          String                                   // "General", "Morning", "Night", "Flexi"
  startTime     String                                   // "09:00"
  endTime       String                                   // "18:00"
  graceMinutes  Int       @default(15)
  isActive      Boolean   @default(true)
  companyId     Int?
  createdAt     DateTime  @default(now())

  company       Company?  @relation(fields: [companyId], references: [id])
}

// ═══════════════════════════════════════════════
// Overtime & Comp-Off
// ═══════════════════════════════════════════════

model OvertimeRequest {
  id            Int       @id @default(autoincrement())
  userId        Int
  date          String                                   // "YYYY-MM-DD"
  hours         Float
  reason        String?
  status        String    @default("pending")            // pending, approved, rejected
  compOffEarned Boolean   @default(false)
  reviewedBy    Int?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  reviewer      User?     @relation("OvertimeReviews", fields: [reviewedBy], references: [id])

  @@unique([userId, date])
}

// ═══════════════════════════════════════════════
// Surveys & Feedback
// ═══════════════════════════════════════════════

model Survey {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  type          String    @default("pulse")              // pulse, engagement, exit, custom
  questions     String                                   // JSON array: [{question, type, options?}]
  isActive      Boolean   @default(true)
  isAnonymous   Boolean   @default(false)
  expiresAt     DateTime?
  companyId     Int?                                     // null = all companies
  createdBy     Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator       User      @relation("SurveyCreator", fields: [createdBy], references: [id])
  company       Company?  @relation(fields: [companyId], references: [id])
  responses     SurveyResponse[]

  @@index([isActive])
}

model SurveyResponse {
  id          Int       @id @default(autoincrement())
  surveyId    Int
  userId      Int?                                       // null if anonymous
  answers     String                                     // JSON: [{questionIndex, answer}]
  submittedAt DateTime  @default(now())

  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ═══════════════════════════════════════════════
// Helpdesk / Ticketing
// ═══════════════════════════════════════════════

model Ticket {
  id            Int       @id @default(autoincrement())
  userId        Int                                       // ticket creator
  subject       String
  description   String
  category      String    @default("hr")                  // it, hr, admin, facilities, other
  priority      String    @default("medium")              // low, medium, high, urgent
  status        String    @default("open")                // open, in_progress, resolved, closed
  assignedTo    Int?                                      // admin/support userId
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  assignee      User?     @relation("TicketAssignee", fields: [assignedTo], references: [id])
  comments      TicketComment[]

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
}

model TicketComment {
  id          Int       @id @default(autoincrement())
  ticketId    Int
  userId      Int
  content     String
  isInternal  Boolean   @default(false)                   // admin-only notes
  createdAt   DateTime  @default(now())

  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

// ═══════════════════════════════════════════════
// OTP Verification
// ═══════════════════════════════════════════════

model OtpVerification {
  id          Int       @id @default(autoincrement())
  userId      Int
  phone       String
  otp         String
  purpose     String    @default("mobile_verify")          // mobile_verify, emergency_verify
  verified    Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@index([phone, otp])
  @@index([userId])
}

// ═══════════════════════════════════════════════
// Asset Handover (Exit/Transfer tracking)
// ═══════════════════════════════════════════════

model AssetHandover {
  id            Int       @id @default(autoincrement())
  assetId       Int
  fromUserId    Int
  toUserId      Int?                                       // null = returned to office pool
  handoverType  String    @default("return")               // return, transfer, exit_return
  condition     String    @default("good")                 // good, damaged, lost
  notes         String?
  handoverDate  String                                     // "YYYY-MM-DD"
  receivedBy    Int?                                       // admin who received
  createdAt     DateTime  @default(now())

  asset         Asset     @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([fromUserId])
}

// ═══════════════════════════════════════════════
// Employee Wiki / Knowledge Base
// ═══════════════════════════════════════════════

model WikiArticle {
  id            Int       @id @default(autoincrement())
  title         String
  content       String                                     // markdown content
  category      String    @default("general")              // travel, contacts, food, emergency, office_info, general
  location      String?                                    // Miraroad, Lucknow, or null for all
  isPinned      Boolean   @default(false)
  createdBy     Int
  lastEditedBy  Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([category])
  @@index([location])
  @@index([isActive])
}

// ═══════════════════════════════════════════════
// Anonymous Suggestions
// ═══════════════════════════════════════════════

model Suggestion {
  id            Int       @id @default(autoincrement())
  content       String
  category      String    @default("general")              // general, improvement, complaint, appreciation
  userId        Int                                        // hidden from all except admin
  adminReply    String?
  status        String    @default("new")                  // new, reviewed, acknowledged, implemented
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════
// Training & Exam System
// ═══════════════════════════════════════════════

model TrainingModule {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  category      String    @default("general")              // general, compliance, technical, soft_skills, ai, onboarding
  content       String                                     // markdown/html training material
  duration      Int?                                       // estimated minutes
  passingScore  Int       @default(70)                     // % to pass exam
  isActive      Boolean   @default(true)
  isMandatory   Boolean   @default(false)
  createdBy     Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  exams         TrainingExam[]
  attempts      TrainingAttempt[]

  @@index([category])
  @@index([isActive])
}

model TrainingExam {
  id            Int       @id @default(autoincrement())
  moduleId      Int
  questions     String                                     // JSON: [{question, options:[], correctAnswer, points}]
  totalPoints   Int       @default(100)
  timeLimit     Int?                                       // minutes, null = unlimited
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  module        TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

model TrainingAttempt {
  id            Int       @id @default(autoincrement())
  moduleId      Int
  userId        Int
  answers       String?                                    // JSON: [{questionIndex, selectedAnswer}]
  score         Float     @default(0)                      // percentage scored
  totalPoints   Int       @default(0)
  passed        Boolean   @default(false)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  timeSpent     Int?                                       // seconds

  module        TrainingModule @relation(fields: [moduleId], references: [id])

  @@index([userId])
  @@index([moduleId])
  @@index([userId, moduleId])
}

// ═══════════════════════════════════════════════
// Expense Approval History
// ═══════════════════════════════════════════════

model ExpenseApprovalLog {
  id            Int       @id @default(autoincrement())
  expenseId     Int
  action        String                                     // submitted, approved, rejected, paid
  actionBy      Int
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([expenseId])
  @@index([actionBy])
}
