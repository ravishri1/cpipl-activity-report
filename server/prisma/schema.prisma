generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  password           String
  role               String   @default("member") // admin, team_lead, member
  department         String   @default("General")
  isActive           Boolean  @default(true)
  googleId           String?  @unique
  importedFromGoogle Boolean  @default(false)
  totalPoints        Int      @default(0) // cached leaderboard score
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // ── HR Profile Fields ──
  employeeId         String?  @unique          // "CPIPL-001" format
  designation        String?                   // "Software Engineer"
  dateOfJoining      String?                   // "YYYY-MM-DD"
  dateOfBirth        String?                   // "YYYY-MM-DD"
  employmentType     String   @default("full_time") // full_time, part_time, contract, intern
  phone              String?
  personalEmail      String?
  address            String?
  emergencyContact   String?                   // JSON: {"name","phone","relation"}
  gender             String?                   // male, female, other
  bloodGroup         String?
  profilePhotoUrl    String?
  reportingManagerId Int?

  // ── Extended Profile (greytHR-style) ──
  // Personal
  maritalStatus      String?                   // single, married, divorced, widowed
  nationality        String?  @default("Indian")
  fatherName         String?
  spouseName         String?
  religion           String?
  placeOfBirth       String?
  permanentAddress   String?                   // separate from current address
  // Identity Documents
  aadhaarNumber      String?
  panNumber          String?
  passportNumber     String?
  passportExpiry     String?                   // "YYYY-MM-DD"
  drivingLicense     String?
  uanNumber          String?                   // Universal Account Number (PF)
  // Bank Details
  bankName           String?
  bankAccountNumber  String?
  bankBranch         String?
  bankIfscCode       String?
  // Employment Extended
  confirmationDate   String?                   // "YYYY-MM-DD"
  probationEndDate   String?                   // "YYYY-MM-DD"
  noticePeriodDays   Int?     @default(30)
  previousExperience Float?   @default(0)      // years
  location           String?                   // office/branch location
  grade              String?                   // pay grade / level
  shift              String?  @default("General") // shift name

  // ── Company ──
  companyId          Int?
  company            Company? @relation(fields: [companyId], references: [id])

  // ── Existing Relations ──
  reports          DailyReport[]
  reminders        Reminder[]
  googleToken      GoogleToken?
  emailActivities  EmailActivity[]
  chatActivities   ChatActivity[]
  pointLogs        PointLog[]
  thumbsUpsGiven   ThumbsUp[]    @relation("ThumbsUpGiver")
  thumbsUpsReceived ThumbsUp[]   @relation("ThumbsUpReceiver")
  appreciationsGiven    Appreciation[]      @relation("AppreciationsGiven")
  appreciationsReceived Appreciation[]      @relation("AppreciationsReceived")
  appreciationBudgets   AppreciationBudget[]

  // ── HR Relations ──
  reportingManager   User?    @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  subordinates       User[]   @relation("ReportingManager")
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  documents          EmployeeDocument[]
  educations         Education[]
  familyMembers      FamilyMember[]
  previousEmployments PreviousEmployment[]
  profileChangeLogs  ProfileChangeLog[]   @relation("ProfileChanges")
  changesLoggedBy    ProfileChangeLog[]   @relation("ChangesMadeBy")
}

model DailyReport {
  id            Int      @id @default(autoincrement())
  userId        Int
  reportDate    String   // YYYY-MM-DD format for easy querying
  activities    String
  challenges    String   @default("")
  planTomorrow  String   @default("")
  totalHours    Float    @default(0)
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id])
  tasks     ReportTask[]
  thumbsUps ThumbsUp[]

  @@unique([userId, reportDate])
}

model ReportTask {
  id          Int    @id @default(autoincrement())
  reportId    Int
  description String
  hours       Float  @default(0)

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Reminder {
  id           Int      @id @default(autoincrement())
  userId       Int
  reportDate   String   // YYYY-MM-DD
  reminderType String   // "first" or "escalation"
  sentAt       DateTime @default(now())
  status       String   @default("sent") // sent, acknowledged

  user User @relation(fields: [userId], references: [id])

  @@index([userId, reportDate])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model GoogleToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmailActivity {
  id             Int      @id @default(autoincrement())
  userId         Int
  activityDate   String   // YYYY-MM-DD
  emailsSent     Int      @default(0)
  emailsReceived Int      @default(0)
  fetchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model ChatActivity {
  id           Int      @id @default(autoincrement())
  userId       Int
  activityDate String   // YYYY-MM-DD
  messagesSent Int      @default(0)
  fetchedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model PointLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  date        String   // YYYY-MM-DD
  source      String   // report, calendar, task, email, chat, thumbsup
  points      Int
  description String   @default("")
  givenBy     Int?     // userId of team lead (for thumbsup only)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([date])
  @@index([source])
}

model ThumbsUp {
  id             Int      @id @default(autoincrement())
  reportId       Int
  givenByUserId  Int
  receiverUserId Int
  createdAt      DateTime @default(now())

  report   DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  givenBy  User        @relation("ThumbsUpGiver", fields: [givenByUserId], references: [id])
  receiver User        @relation("ThumbsUpReceiver", fields: [receiverUserId], references: [id])

  @@unique([reportId, givenByUserId])
  @@index([receiverUserId])
}

model Appreciation {
  id          Int      @id @default(autoincrement())
  giverId     Int
  receiverId  Int
  points      Int      @default(5)
  reason      String
  status      String   @default("normal") // normal, warned, penalized
  flagReason  String?
  createdAt   DateTime @default(now())

  giver    User @relation("AppreciationsGiven", fields: [giverId], references: [id])
  receiver User @relation("AppreciationsReceived", fields: [receiverId], references: [id])

  @@index([giverId])
  @@index([receiverId])
  @@index([createdAt])
}

model AppreciationBudget {
  id           Int    @id @default(autoincrement())
  userId       Int
  weekStart    String // YYYY-MM-DD (Monday)
  totalGiven   Int    @default(0)
  warningCount Int    @default(0)
  penaltyCount Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
}

// ═══════════════════════════════════════════════
// HR Core Models
// ═══════════════════════════════════════════════

model Attendance {
  id        Int       @id @default(autoincrement())
  userId    Int
  date      String                              // "YYYY-MM-DD"
  checkIn   DateTime?
  checkOut  DateTime?
  status    String    @default("present")       // present, absent, half_day, on_leave, holiday, weekend
  workHours Float?                              // auto-calc from checkIn/checkOut
  ipAddress String?
  notes     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
}

model LeaveType {
  id              Int      @id @default(autoincrement())
  name            String   @unique              // "Casual Leave", "Sick Leave", "Earned Leave"
  code            String   @unique              // "CL", "SL", "EL"
  defaultBalance  Float    @default(0)          // annual entitlement
  carryForward    Boolean  @default(false)
  maxCarryForward Float    @default(0)
  isActive        Boolean  @default(true)

  balances LeaveBalance[]
  requests LeaveRequest[]
}

model LeaveBalance {
  id          Int   @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  year        Int                               // 2026
  total       Float @default(0)                 // allocated
  used        Float @default(0)                 // consumed
  balance     Float @default(0)                 // remaining = total - used

  user      User      @relation(fields: [userId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([userId, leaveTypeId, year])
}

model LeaveRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  startDate   String                            // "YYYY-MM-DD"
  endDate     String                            // "YYYY-MM-DD"
  days        Float                             // computed (supports half-days: 0.5)
  reason      String
  status      String    @default("pending")     // pending, approved, rejected, cancelled
  reviewedBy  Int?                              // userId of approver
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

model Holiday {
  id         Int     @id @default(autoincrement())
  name       String                              // "Republic Day"
  date       String                              // "YYYY-MM-DD"
  year       Int
  isOptional Boolean @default(false)

  @@unique([date])
  @@index([year])
}

model Education {
  id           Int     @id @default(autoincrement())
  userId       Int
  degree       String                              // "B.Tech", "MBA", "12th"
  institution  String                              // "IIT Delhi"
  university   String?                             // "Delhi University"
  specialization String?                           // "Computer Science"
  yearOfPassing String?                            // "2020"
  percentage   String?                             // "85%" or "8.5 CGPA"

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model FamilyMember {
  id           Int     @id @default(autoincrement())
  userId       Int
  name         String
  relationship String                              // father, mother, spouse, child, sibling
  dateOfBirth  String?                             // "YYYY-MM-DD"
  occupation   String?
  phone        String?
  isDependent  Boolean @default(false)
  isNominee    Boolean @default(false)             // EPF/Gratuity nominee
  nomineeShare Float?                              // percentage share

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model PreviousEmployment {
  id           Int     @id @default(autoincrement())
  userId       Int
  company      String
  designation  String?
  fromDate     String?                             // "YYYY-MM-DD"
  toDate       String?                             // "YYYY-MM-DD"
  ctc          String?                             // last drawn CTC
  reasonForLeaving String?

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model EmployeeDocument {
  id         Int      @id @default(autoincrement())
  userId     Int
  name       String                              // "Aadhar Card"
  type       String                              // "id_proof", "address_proof", "education", "other"
  fileUrl    String                              // Vercel Blob URL
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ProfileChangeLog {
  id          Int      @id @default(autoincrement())
  userId      Int                                   // employee whose profile was changed
  changedBy   Int                                   // user who made the change
  section     String                                // "profile", "education", "family", "employment", "photo"
  field       String                                // field name or sub-record description
  oldValue    String?                               // previous value (null for new additions)
  newValue    String?                               // new value
  action      String   @default("update")           // "update", "add", "delete"
  createdAt   DateTime @default(now())

  user      User @relation("ProfileChanges", fields: [userId], references: [id])
  changedByUser User @relation("ChangesMadeBy", fields: [changedBy], references: [id])

  @@index([userId, createdAt])
  @@index([changedBy])
}

// ═══════════════════════════════════════════════
// Company Model
// ═══════════════════════════════════════════════

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  shortName String?                              // "CPIPL", "Gimmick"
  gst       String?
  state     String?
  city      String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users     User[]
}
