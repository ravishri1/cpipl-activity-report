generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  password           String
  role               String   @default("member") // admin, team_lead, member
  department         String   @default("General")
  isActive           Boolean  @default(true)
  employmentStatus   String   @default("active") // active, notice_period, separated, terminated, absconding
  isHibernated              Boolean  @default(false)
  lastActivityAt            DateTime?
  selfReactivationCount     Int      @default(0)    // resets monthly, max 3 self-unlocks
  selfReactivationMonth     String?                 // "YYYY-MM" to track reset
  googleId           String?  @unique
  clerkId            String?  @unique  // Clerk user ID — cached to avoid Clerk API calls on every request
  importedFromGoogle Boolean  @default(false)
  totalPoints        Int      @default(0) // cached leaderboard score
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // ── HR Profile Fields ──
  employeeId         String?  @unique          // "CPIPL-001" format
  designation        String?                   // "Software Engineer"
  dateOfJoining      String?                   // "YYYY-MM-DD"
  dateOfBirth        String?                   // "YYYY-MM-DD"
  employmentType     String   @default("full_time") // full_time, part_time, contract, intern
  phone              String?
  phoneVerified      Boolean  @default(false)
  personalEmail      String?
  address            String?
  emergencyContact   String?                   // JSON: [{"name","fatherName","phone","relation"}] (2 refs)
  emergencyContact2  String?                   // JSON: {"name","fatherName","phone","relation"} (2nd ref)
  gender             String?                   // male, female, other
  bloodGroup         String?
  profilePhotoUrl      String?
  driveProfilePhotoUrl String?              // Google Drive URL for profile photo (preferred over base64)
  driveFolderId        String?              // Google Drive folder ID for this employee
  reportingManagerId Int?

  // ── Extended Profile (greytHR-style) ──
  // Personal
  maritalStatus      String?                   // single, married, divorced, widowed
  nationality        String?  @default("Indian")
  fatherName         String?
  spouseName         String?
  religion           String?
  placeOfBirth       String?
  permanentAddress   String?                   // separate from current address
  // Identity Documents
  aadhaarNumber      String?
  panNumber          String?
  passportNumber     String?
  passportExpiry     String?                   // "YYYY-MM-DD"
  drivingLicense     String?
  uanNumber          String?                   // Universal Account Number (PF)
  // Bank Details
  bankName           String?
  bankAccountNumber  String?
  bankBranch         String?
  bankIfscCode       String?
  // Employment Extended
  confirmationDate   String?                   // "YYYY-MM-DD"
  probationEndDate   String?                   // "YYYY-MM-DD"
  noticePeriodDays   Int?     @default(30)
  previousExperience Float?   @default(0)      // years
  location           String?                   // office/branch location
  grade              String?                   // pay grade / level
  shift              String?  @default("General") // shift name
  shiftId            Int?                        // Current shift assignment
  shiftAssignments   ShiftAssignment[]           @relation("ShiftAssignments")    // History of shift assignments by this user
  shiftAssignmentsCreated ShiftAssignment[]      @relation("ShiftAssignmentsCreatedBy")  // Shift assignments created by this user (manager)

  // ── Company ──
  companyId          Int?
  company            Company? @relation(fields: [companyId], references: [id])

  // ── Company Master (GSTIN-level registration) ──
  companyRegistrationId  Int?
  companyRegistration    CompanyRegistration? @relation("UserCompanyRegistration", fields: [companyRegistrationId], references: [id])

  // ── Employee Type & Branch ──
  employeeType              String   @default("internal")   // internal | intern | external
  officialEmailDisabled     Boolean  @default(false)
  workspaceSuspendPending   Boolean  @default(false)  // HR must manually suspend/delete Workspace account
  workspaceSuspendDoneAt    String?                   // "YYYY-MM-DD" when HR confirmed suspension done
  sectionPermissions        Json?                     // Array of route paths to DENY: ["/admin/payroll", "/payslips"]
  branchId                  Int?
  branch                    Branch?  @relation(fields: [branchId], references: [id])
  costCenterId              Int?
  costCenter                Company? @relation("CostCenter", fields: [costCenterId], references: [id])
  confirmationStatus        String?  // pending | extended | confirmed (null = N/A)
  confirmedAt               String?  // "YYYY-MM-DD"
  benefitsUnlocked          Boolean  @default(false)
  isAttendanceExempt        Boolean  @default(false) // Bypass all attendance rules — always marked Present
  attendanceExemptReason    String?  // "Management", "Director", "Business Travel", etc.

  // ── Existing Relations ──
  reports          DailyReport[]
  reminders        Reminder[]
  googleToken      GoogleToken?
  emailActivities  EmailActivity[]
  chatActivities   ChatActivity[]
  pointLogs        PointLog[]
  thumbsUpsGiven   ThumbsUp[]    @relation("ThumbsUpGiver")
  thumbsUpsReceived ThumbsUp[]   @relation("ThumbsUpReceiver")
  appreciationsGiven    Appreciation[]      @relation("AppreciationsGiven")
  appreciationsReceived Appreciation[]      @relation("AppreciationsReceived")
  appreciationBudgets   AppreciationBudget[]

  // ── HR Relations ──
  reportingManager   User?    @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  subordinates       User[]   @relation("ReportingManager")
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  leaveGrantsReceived LeaveGranter[]  @relation("LeaveGranterUser")
  leaveGrantsGiven    LeaveGranter[]  @relation("LeaveGranterAdmin")
  documents          EmployeeDocument[]
  educations         Education[]
  familyMembers      FamilyMember[]
  previousEmployments PreviousEmployment[]
  profileChangeLogs  ProfileChangeLog[]   @relation("ProfileChanges")
  changesLoggedBy    ProfileChangeLog[]   @relation("ChangesMadeBy")
  policyAcceptances  PolicyAcceptance[]
  salaryStructure    SalaryStructure?
  payslips           Payslip[]
  salaryRevisions    SalaryRevision[]
  payrollArrears     PayrollArrear[]
  salaryRevisionsBy  SalaryRevision[]   @relation("SalaryRevisionsBy")
  expenseClaims      ExpenseClaim[]
  expenseReviews     ExpenseClaim[]     @relation("ExpenseReviews")
  fundRequests       FundRequest[]      @relation("FundRequests")
  fundRequestReviews FundRequest[]      @relation("FundRequestReviews")
  fundDisbursements  FundRequest[]      @relation("FundDisbursements")
  fundBalance        EmployeeFundBalance? @relation("EmployeeFundBalance")
  fundBalancesSet    EmployeeFundBalance[] @relation("FundBalanceSetBy")
  announcements      Announcement[]     @relation("AnnouncementAuthor")
  generatedLetters   GeneratedLetter[]
  lettersGeneratedBy GeneratedLetter[]  @relation("LetterGeneratedBy")
  assignedAssets     Asset[]            @relation("AssetAssignment")
  onboardingTasks    OnboardingChecklist[]
  separation         Separation?
  separationHandler  Separation[]       @relation("SeparationHandler")
  surveyResponses    SurveyResponse[]
  surveysCreated     Survey[]           @relation("SurveyCreator")
  tickets            Ticket[]
  assignedTickets    Ticket[]           @relation("TicketAssignee")
  ticketComments     TicketComment[]
  otpRequests        OtpVerification[]
  driveFiles         DriveFile[]
  insuranceCard     InsuranceCard?                        // Current/active insurance card
  insuranceCardsUploaded InsuranceCard[]                 @relation("InsuranceCardsUploaded")  // Cards uploaded by this admin

  // ── Asset Repair/Maintenance ──
  repairsInitiated  AssetRepair[]                        @relation("RepairInitiator")       // Repairs initiated by this user
  repairsCompleted  AssetRepair[]                        @relation("RepairCompleter")       // Repairs completed by this user

  // ── Asset Lifecycle Management ──
  locationIncharge           Location[]                   @relation("LocationIncharge")      // Locations this user manages
  assetAssigneeMaster        AssetAssignment[]            @relation("AssetAssignee")         // Assets assigned to this user
  assetAssignmentsMade       AssetAssignment[]            @relation("AssignmentCreator")     // Assignments created by this user
  assetAssignmentsReceived   AssetAssignment[]            @relation("AssignmentReturner")    // Assets returned to office by this user
  assetMovementsMade         AssetMovement[]                                                 // Movements created by this user
  assetConditionChecks       AssetConditionLog[]                                             // Condition checks done by this user
  assetDisposalsApproved     AssetDisposal[]              @relation("DisposalApprover")      // Disposals approved by this user
  assetDisposalsCreated      AssetDisposal[]              @relation("DisposalCreator")       // Disposals requested by this user
  detachmentRequestsCreated  AssetDetachmentRequest[]     @relation("DetachmentRequester")   // Detachment requests by this employee
  detachmentRequestsApproved AssetDetachmentRequest[]     @relation("DetachmentApprover")    // Requests approved by this user

  // ── Predictive Maintenance Relations ──
  maintenanceRecommendationApprovals MaintenanceRecommendation[] @relation("MaintenanceApprover") // Recommendations approved by this user

  // ── Error Reporting ──
  errorReports               ErrorReport[]                @relation("ErrorReporter")
  errorReportsResolved       ErrorReport[]                @relation("ErrorResolver")

  // ── Biometric Integration ──
  bioDeviceId               String?                       // Device enroll number (e.g. "EMP001") for biometric matching
  biometricPunches          BiometricPunch[]              @relation("PunchEmployee")

  // ── Confirmation Workflow ──
  confirmationExtensions    ConfirmationExtension[]       @relation("ConfirmationExtensions")
  extensionsGranted         ConfirmationExtension[]       @relation("ConfirmationExtensionsBy")
  contractsCreated          CompanyContract[]             @relation("ContractCreator")
  contractsCounterSigned    CompanyContract[]             @relation("ContractInternalSigner")
  contractTemplatesCreated  ContractTemplate[]            @relation("ContractTemplateCreator")
  statementUploads          MonthlyStatement[]            @relation("StatementUploader")
  renewalHistory            RenewalHistory[]              @relation("RenewalHistoryPerformer")
  emailScansReviewed        EmailRenewalScan[]            @relation("EmailScanReviewer")

  // ── CompOff ──
  compOffBalances           CompOffBalance[]
  compOffRequests           CompOffRequest[]
  compOffReviewed           CompOffRequest[]              @relation("CompOffReviewer")

  // ── Attendance Regularization ──
  regularizationRequests    AttendanceRegularization[]
  regularizationReviewed    AttendanceRegularization[]   @relation("RegularizationReviewer")

  // ── Recruitment ──
  jobOpeningsPosted         JobOpening[]                 @relation("JobPoster")
  candidateReferrals        Candidate[]                  @relation("CandidateReferral")
  interviewsConducted       Interview[]                  @relation("InterviewConductor")
  offersGenerated           JobOffer[]                   @relation("OfferGenerator")

  // ── Email Work Tracker ──
  emailHandledThreads       EmailHandledThread[]

  // ── Monthly Ledger ──
  monthlyLedgers            MonthlyLedger[]      @relation("MonthlyLedgers")
  ledgersLocked             MonthlyLedger[]      @relation("LedgerLockedBy")
  ledgersGenerated          MonthlyLedger[]      @relation("LedgerGeneratedBy")
  ledgerAdjustments         LedgerAdjustment[]   @relation("LedgerAdjustments")
  ledgerAdjustmentsCreated  LedgerAdjustment[]   @relation("LedgerAdjustmentCreator")

  // ── Weekly Off Pattern ──
  weeklyOffPatternId        Int?
  weeklyOffPattern          WeeklyOffPattern?  @relation("UserWeeklyOff", fields: [weeklyOffPatternId], references: [id])

  @@index([department])
  @@index([isActive])
  @@index([employmentStatus])
  @@index([isHibernated])
  @@index([companyId])
  @@index([reportingManagerId])
  @@index([role])
  @@index([createdAt])
  @@index([branchId])
  @@index([employeeType])
  @@index([bioDeviceId])
  @@index([companyRegistrationId])
}

model DailyReport {
  id            Int      @id @default(autoincrement())
  userId        Int
  reportDate    String   // YYYY-MM-DD format for easy querying
  activities    String
  challenges    String   @default("")
  planTomorrow  String   @default("")
  totalHours    Float    @default(0)
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id])
  tasks     ReportTask[]
  thumbsUps ThumbsUp[]

  @@unique([userId, reportDate])
  @@index([reportDate])
  @@index([submittedAt])
}

model ReportTask {
  id          Int    @id @default(autoincrement())
  reportId    Int
  description String
  hours       Float  @default(0)

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Reminder {
  id           Int      @id @default(autoincrement())
  userId       Int
  reportDate   String   // YYYY-MM-DD
  reminderType String   // "first" or "escalation"
  sentAt       DateTime @default(now())
  status       String   @default("sent") // sent, acknowledged

  user User @relation(fields: [userId], references: [id])

  @@index([userId, reportDate])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model GoogleToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmailHandledThread {
  id        Int      @id @default(autoincrement())
  userId    Int
  threadId  String
  date      String   // "2026-03-12" format
  action    String   // 'added_to_report' | 'pushed_to_task' | 'marked_handled'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, threadId, date])
  @@index([userId, date])
}

model EmailActivity {
  id             Int      @id @default(autoincrement())
  userId         Int
  activityDate   String   // YYYY-MM-DD
  emailsSent     Int      @default(0)
  emailsReceived Int      @default(0)
  fetchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model ChatActivity {
  id           Int      @id @default(autoincrement())
  userId       Int
  activityDate String   // YYYY-MM-DD
  messagesSent Int      @default(0)
  fetchedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model PointLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  date        String   // YYYY-MM-DD
  source      String   // report, calendar, task, email, chat, thumbsup
  points      Int
  description String   @default("")
  givenBy     Int?     // userId of team lead (for thumbsup only)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([date])
  @@index([source])
}

model ThumbsUp {
  id             Int      @id @default(autoincrement())
  reportId       Int
  givenByUserId  Int
  receiverUserId Int
  createdAt      DateTime @default(now())

  report   DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  givenBy  User        @relation("ThumbsUpGiver", fields: [givenByUserId], references: [id])
  receiver User        @relation("ThumbsUpReceiver", fields: [receiverUserId], references: [id])

  @@unique([reportId, givenByUserId])
  @@index([receiverUserId])
}

model Appreciation {
  id          Int      @id @default(autoincrement())
  giverId     Int
  receiverId  Int
  points      Int      @default(5)
  reason      String
  status      String   @default("normal") // normal, warned, penalized
  flagReason  String?
  createdAt   DateTime @default(now())

  giver    User @relation("AppreciationsGiven", fields: [giverId], references: [id])
  receiver User @relation("AppreciationsReceived", fields: [receiverId], references: [id])

  @@index([giverId])
  @@index([receiverId])
  @@index([createdAt])
}

model AppreciationBudget {
  id           Int    @id @default(autoincrement())
  userId       Int
  weekStart    String // YYYY-MM-DD (Monday)
  totalGiven   Int    @default(0)
  warningCount Int    @default(0)
  penaltyCount Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
}

// ═══════════════════════════════════════════════
// HR Core Models
// ═══════════════════════════════════════════════

model Attendance {
  id        Int       @id @default(autoincrement())
  userId    Int
  date      String                              // "YYYY-MM-DD"
  checkIn   DateTime?
  checkOut  DateTime?
  status    String    @default("present")       // present, absent, half_day, on_leave, holiday, weekend
  workHours Float?                              // auto-calc from checkIn/checkOut
  ipAddress String?
  notes     String?
  session1       String?                            // "P", "A", "L" — First session status (admin override)
  session2       String?                            // "P", "A", "L" — Second session status (admin override)
  adminOverride  Boolean   @default(false)          // Whether admin manually set this status
  adminRemark    String?                            // Admin remark when overriding
  overriddenBy   Int?                               // Admin user who overrode
  overriddenAt   DateTime?                          // When the override happened

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
}

model LeaveType {
  id              Int      @id @default(autoincrement())
  name            String   @unique              // "Privilege Leave"
  code            String   @unique              // "PL"
  defaultBalance  Float    @default(0)          // annual entitlement (e.g., 12)
  accrualType     String   @default("monthly")  // "monthly" = 1/month bucket, "yearly" = all at once, "none"
  accrualAmount   Float    @default(1)          // how many credited per period (1/month for PL)
  carryForward    Boolean  @default(false)
  maxCarryForward Float    @default(0)
  isActive        Boolean  @default(true)

  balances LeaveBalance[]
  requests LeaveRequest[]
  granters LeaveGranter[]
}

model LeaveBalance {
  id          Int   @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  year        Int                               // financial year START year (2025 = FY Apr 2025 - Mar 2026)
  opening     Float @default(0)                 // carry forward from previous FY
  total       Float @default(0)                 // annual entitlement (e.g., 12)
  used        Float @default(0)                 // consumed (approved leaves)
  balance     Float @default(0)                 // available = opening + credited - used (kept in sync)
  probationAllowance Float?                     // leaves usable during probation (e.g., 1). null = no restriction
  joiningMonth       Int?                       // 1-12 (FY month employee joined, for pro-rated accrual)

  user      User      @relation(fields: [userId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([userId, leaveTypeId, year])
}

model LeaveGranter {
  id          Int      @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  fyYear      Int                               // financial year start year
  totalGranted Float                            // total leaves granted for this FY (e.g., 6 for mid-year joiner)
  probationAllowance Float @default(1)          // usable during probation period (e.g., 1)
  joiningMonth Int?                             // FY month of joining (1=Apr, 12=Mar). null = full year
  notes       String?                           // admin notes
  isLocked    Boolean  @default(false)          // locked for payroll — prevents edit/delete
  grantedBy   Int                               // admin userId who granted
  grantedAt   DateTime @default(now())

  user      User      @relation("LeaveGranterUser", fields: [userId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
  granter   User      @relation("LeaveGranterAdmin", fields: [grantedBy], references: [id])

  @@unique([userId, leaveTypeId, fyYear])
  @@index([userId])
}

model LeaveRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  leaveTypeId Int
  startDate   String                            // "YYYY-MM-DD"
  endDate     String                            // "YYYY-MM-DD"
  days        Float                             // computed (supports half-days: 0.5)
  session     String    @default("full_day")    // "full_day", "first_half", "second_half"
  reason      String
  status      String    @default("pending")     // pending, approved, rejected, cancelled
  reviewedBy  Int?                              // userId of approver
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

model Holiday {
  id         Int     @id @default(autoincrement())
  name       String                              // "Republic Day"
  date       String                              // "YYYY-MM-DD"
  year       Int
  isOptional Boolean @default(false)
  location   String  @default("All")             // "All", "Mumbai", "Lucknow", or comma-separated

  @@unique([date, location])
  @@index([year])
}

model WeeklyOffPattern {
  id        Int      @id @default(autoincrement())
  name      String   @unique                     // "Sat+Sun", "Thu+Sat", "Fri+Sat"
  days      String                               // JSON array of day numbers: "[0,6]" for Sun+Sat
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  users     User[]   @relation("UserWeeklyOff")
}

model Education {
  id           Int     @id @default(autoincrement())
  userId       Int
  degree       String                              // "B.Tech", "MBA", "12th"
  institution  String                              // "IIT Delhi"
  university   String?                             // "Delhi University"
  specialization String?                           // "Computer Science"
  yearOfPassing String?                            // "2020"
  percentage   String?                             // "85%" or "8.5 CGPA"

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model FamilyMember {
  id           Int     @id @default(autoincrement())
  userId       Int
  name         String
  relationship String                              // father, mother, spouse, child, sibling
  dateOfBirth  String?                             // "YYYY-MM-DD"
  occupation   String?
  phone        String?
  isDependent  Boolean @default(false)
  isNominee    Boolean @default(false)             // EPF/Gratuity nominee
  nomineeShare Float?                              // percentage share

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model PreviousEmployment {
  id           Int     @id @default(autoincrement())
  userId       Int
  company      String
  designation  String?
  fromDate     String?                             // "YYYY-MM-DD"
  toDate       String?                             // "YYYY-MM-DD"
  ctc          String?                             // last drawn CTC
  reasonForLeaving String?

  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model EmployeeDocument {
  id         Int      @id @default(autoincrement())
  userId     Int
  name       String                              // "Aadhar Card"
  type       String                              // "id_proof", "address_proof", "education", "other"
  fileUrl    String                              // Vercel Blob URL
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ProfileChangeLog {
  id          Int      @id @default(autoincrement())
  userId      Int                                   // employee whose profile was changed
  changedBy   Int                                   // user who made the change
  section     String                                // "profile", "education", "family", "employment", "photo"
  field       String                                // field name or sub-record description
  oldValue    String?                               // previous value (null for new additions)
  newValue    String?                               // new value
  action      String   @default("update")           // "update", "add", "delete"
  createdAt   DateTime @default(now())

  user      User @relation("ProfileChanges", fields: [userId], references: [id])
  changedByUser User @relation("ChangesMadeBy", fields: [changedBy], references: [id])

  @@index([userId, createdAt])
  @@index([changedBy])
}

// ═══════════════════════════════════════════════
// Company Model
// ═══════════════════════════════════════════════

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  shortName String?                              // "CPIPL", "Gimmick"
  gst       String?
  state     String?
  city      String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users         User[]
  policies      Policy[]
  announcements Announcement[]
  assets           Asset[]
  shiftDefinitions ShiftDefinition[]
  shifts        Shift[]
  surveys          Survey[]
  
  // Asset Lifecycle Management
  locations        Location[]
  costCenterEmployees  User[]       @relation("CostCenter")
  contracts        CompanyContract[]
  branches         Branch[]
}

// ═══════════════════════════════════════════════
// Policy Management
// ═══════════════════════════════════════════════

model Policy {
  id            Int      @id @default(autoincrement())
  title         String                                // "Work From Home Policy"
  slug          String   @unique                      // "work-from-home-policy"
  category      String   @default("general")          // general, attendance, leave, conduct, benefits, safety
  content       String                                // Full policy text (markdown/HTML)
  summary       String?                               // Brief summary for listing
  version       Int      @default(1)                  // version number
  effectiveDate String?                               // "YYYY-MM-DD"
  isActive      Boolean  @default(true)
  isMandatory   Boolean  @default(true)               // Must all employees accept?
  companyId     Int?                                   // null = applies to all companies
  createdBy     Int?                                   // admin who created it
  protectionScore Float? @default(0)                   // 0-100 score of how well policy protects company
  scoreBreakdown  String?                              // JSON: {"legal":80,"compliance":70,...}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company?           @relation(fields: [companyId], references: [id])
  sections      PolicySection[]
  acceptances   PolicyAcceptance[]
  versions      PolicyVersion[]

  @@index([category])
  @@index([isActive])
}

model PolicySection {
  id        Int     @id @default(autoincrement())
  policyId  Int
  title     String                                    // "Scope", "Eligibility", "Procedure"
  content   String                                    // Section text
  sortOrder Int     @default(0)
  isEditable Boolean @default(false)                  // HR can customize this section per employee

  policy    Policy  @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

model PolicyAcceptance {
  id         Int      @id @default(autoincrement())
  policyId   Int
  userId     Int
  version    Int      @default(1)                     // which version was accepted
  acceptedAt DateTime @default(now())
  ipAddress  String?
  remarks    String?                                  // optional employee comment

  policy     Policy @relation(fields: [policyId], references: [id])
  user       User   @relation(fields: [userId], references: [id])

  @@unique([policyId, userId, version])
  @@index([userId])
}

model PolicyVersion {
  id        Int      @id @default(autoincrement())
  policyId  Int
  version   Int
  content   String                                    // snapshot of content at this version
  changedBy Int?                                      // admin who made changes
  changeLog String?                                   // what changed
  createdAt DateTime @default(now())

  policy    Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, version])
}

// ═══════════════════════════════════════════════
// Payroll & Salary
// ═══════════════════════════════════════════════

model SalaryStructure {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  ctcAnnual            Float                          // Annual CTC
  ctcMonthly           Float                          // CTC / 12

  // Earnings
  basic                Float    @default(0)
  hra                  Float    @default(0)
  da                   Float    @default(0)           // Dearness Allowance
  specialAllowance     Float    @default(0)
  medicalAllowance     Float    @default(0)
  conveyanceAllowance  Float    @default(0)
  otherAllowance       Float    @default(0)
  otherAllowanceLabel  String?                        // custom label for other allowance

  // Employer Contributions (not part of net pay)
  employerPf           Float    @default(0)
  employerEsi          Float    @default(0)

  // Employee Deductions
  employeePf           Float    @default(0)
  employeeEsi          Float    @default(0)
  professionalTax      Float    @default(0)
  tds                  Float    @default(0)

  netPayMonthly        Float    @default(0)           // Gross - Deductions
  effectiveFrom        String?                        // "YYYY-MM-DD"
  notes                String?

  // Stop Salary Processing
  stopSalaryProcessing Boolean  @default(false)
  stopSalaryReason     String?
  stopSalaryBy         Int?
  stopSalaryAt         DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id])
}

model PayrollArrear {
  id              Int      @id @default(autoincrement())
  userId          Int
  revisionId      Int?
  fromMonth       String                              // "2026-01"
  toMonth         String                              // "2026-03"
  totalArrears    Float    @default(0)
  breakdown       Json?                               // [{month, oldNet, newNet, arrearAmount}]
  status          String   @default("calculated")     // calculated | applied | cancelled
  appliedInMonth  String?                             // "2026-03" — month when arrears were added
  appliedBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Payslip {
  id                   Int      @id @default(autoincrement())
  userId               Int
  month                String                          // "2026-03"
  year                 Int

  // Earnings
  basic                Float    @default(0)
  hra                  Float    @default(0)
  da                   Float    @default(0)
  specialAllowance     Float    @default(0)
  medicalAllowance     Float    @default(0)
  conveyanceAllowance  Float    @default(0)
  otherAllowance       Float    @default(0)
  otherAllowanceLabel  String?
  grossEarnings        Float    @default(0)

  // Employer Contributions (snapshot for CTC/payslip display)
  employerPf           Float    @default(0)
  employerEsi          Float    @default(0)

  // Deductions
  employeePf           Float    @default(0)
  employeeEsi          Float    @default(0)
  professionalTax      Float    @default(0)
  tds                  Float    @default(0)
  otherDeductions      Float    @default(0)
  otherDeductionsLabel String?
  totalDeductions      Float    @default(0)

  netPay               Float    @default(0)

  // Metadata snapshot
  companyName          String?                         // company name at time of generation

  // Attendance
  workingDays          Int      @default(0)
  presentDays          Float    @default(0)
  lopDays              Float    @default(0)           // Loss of Pay days
  lopDeduction         Float    @default(0)

  status               String   @default("draft")     // draft, generated, published
  generatedAt          DateTime?
  publishedAt          DateTime?
  pdfUrl               String?

  createdAt            DateTime @default(now())

  user                 User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@index([month])
  @@index([status])
}

model SalaryRevision {
  id            Int      @id @default(autoincrement())
  userId        Int
  effectiveFrom String                                // "YYYY-MM-DD"
  oldCtc        Float
  newCtc        Float
  reason        String?
  revisedBy     Int                                   // admin userId
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  revisedByUser User     @relation("SalaryRevisionsBy", fields: [revisedBy], references: [id])

  @@index([userId])
}

// ═══════════════════════════════════════════════
// Salary Templates (Reusable structures)
// ═══════════════════════════════════════════════

model SalaryTemplate {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  description         String?
  ctcAnnual           Float    @default(0)
  basic               Float    @default(0)
  hra                 Float    @default(0)
  da                  Float    @default(0)
  specialAllowance    Float    @default(0)
  medicalAllowance    Float    @default(0)
  conveyanceAllowance Float    @default(0)
  otherAllowance      Float    @default(0)
  otherAllowanceLabel String?
  employerPf          Float    @default(0)
  employerEsi         Float    @default(0)
  employeePf          Float    @default(0)
  employeeEsi         Float    @default(0)
  professionalTax     Float    @default(0)
  tds                 Float    @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ═══════════════════════════════════════════════
// Salary Components (Configurable)
// ═══════════════════════════════════════════════

model SalaryComponent {
  id                Int      @id @default(autoincrement())
  name              String                         // "Basic Salary"
  code              String   @unique               // "BASIC"
  type              String                         // "earning" | "deduction" | "employer"
  taxable           Boolean  @default(true)
  mandatory         Boolean  @default(false)
  calculationType   String   @default("fixed")     // "fixed" | "percentage"
  percentageOf      String?                        // "basic" | "gross" | null
  defaultPercentage Float?                         // e.g. 50.0 for HRA = 50% of basic
  description       String?
  complianceNote    String?                        // IT section reference, limits
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  isSystem          Boolean  @default(false)       // Pre-seeded defaults
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ═══════════════════════════════════════════════
// Expense Claims
// ═══════════════════════════════════════════════

model ExpenseClaim {
  id            Int       @id @default(autoincrement())
  userId        Int
  title         String
  category      String    @default("other")            // travel, food, medical, office, other
  amount        Float
  description   String?
  receiptUrl    String?                                // base64 or URL
  date          String                                 // "YYYY-MM-DD"
  status        String    @default("pending")          // pending, approved, rejected, paid
  reviewedBy    Int?
  reviewedAt    DateTime?
  reviewNote    String?
  paidOn        String?                                // "YYYY-MM-DD"
  fundRequestId Int?                                   // Optional link to fund advance
  items         String?                                // JSON array: [{title,category,amount,date,description}]
  attachments   String?                                // JSON array: [{name,url,driveFileId}]
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  reviewer      User?     @relation("ExpenseReviews", fields: [reviewedBy], references: [id])
  fundRequest   FundRequest? @relation("FundExpenses", fields: [fundRequestId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([date])
  @@index([category])
  @@index([fundRequestId])
}

// ═══════════════════════════════════════════════
// Fund Requests / Advances
// ═══════════════════════════════════════════════

model FundRequest {
  id                Int       @id @default(autoincrement())
  requestedBy       Int
  title             String
  purpose           String?
  amount            Float                                    // Requested amount
  date              String                                   // "YYYY-MM-DD" request date
  status            String    @default("pending")            // pending, approved, rejected, disbursed, acknowledged, settled, cancelled
  type              String    @default("advance")            // advance, reimbursement
  category          String?                                  // For reimbursement: travel, food, office, medical, other
  billUrl           String?                                  // Receipt/bill URL for reimbursement
  billDriveId       String?                                  // Drive file ID for bill
  paymentMode       String?                                  // bank_transfer, cash
  disbursedAmount   Float?                                   // Actual amount disbursed (may differ from requested)
  disbursedOn       String?                                  // "YYYY-MM-DD"
  disbursedBy       Int?
  paymentRef        String?                                  // UTR / transaction reference for bank transfers
  paymentReceiptUrl String?                                  // Receipt URL for bank transfers
  acknowledgedAt    DateTime?
  acknowledgeNote   String?
  reviewedBy        Int?
  reviewedAt        DateTime?
  reviewNote        String?
  settledOn         String?                                  // "YYYY-MM-DD"
  settledNote       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  requester         User      @relation("FundRequests", fields: [requestedBy], references: [id])
  reviewer          User?     @relation("FundRequestReviews", fields: [reviewedBy], references: [id])
  disburser         User?     @relation("FundDisbursements", fields: [disbursedBy], references: [id])
  expenses          ExpenseClaim[] @relation("FundExpenses")
  logs              FundRequestLog[]

  @@index([requestedBy])
  @@index([status])
  @@index([date])
  @@index([type])
}

model EmployeeFundBalance {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  openingBalance Float    @default(0)
  notes          String?
  setBy          Int?
  setDate        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation("EmployeeFundBalance", fields: [userId], references: [id])
  setByUser      User?    @relation("FundBalanceSetBy", fields: [setBy], references: [id])

  @@index([userId])
}

model FundRequestLog {
  id            Int       @id @default(autoincrement())
  fundRequestId Int
  action        String                                       // submitted, approved, rejected, disbursed, acknowledged, expense_linked, settled, cancelled
  actionBy      Int
  notes         String?
  createdAt     DateTime  @default(now())

  fundRequest   FundRequest @relation(fields: [fundRequestId], references: [id])

  @@index([fundRequestId])
  @@index([actionBy])
}

// ═══════════════════════════════════════════════
// Announcements
// ═══════════════════════════════════════════════

model Announcement {
  id            Int       @id @default(autoincrement())
  title         String
  content       String                                 // markdown/rich text
  category      String    @default("general")          // general, policy, event, birthday, anniversary
  priority      String    @default("normal")           // normal, important, urgent
  companyId     Int?                                   // null = all companies
  postedBy      Int
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  company       Company?  @relation(fields: [companyId], references: [id])
  author        User      @relation("AnnouncementAuthor", fields: [postedBy], references: [id])

  @@index([isActive])
  @@index([category])
}

// ═══════════════════════════════════════════════
// Letter Templates & Generated Letters
// ═══════════════════════════════════════════════

model LetterTemplate {
  id          Int       @id @default(autoincrement())
  name        String                                     // "Offer Letter", "Appointment Letter"
  type        String                                     // offer, appointment, salary_revision, experience, relieving, custom
  content     String                                     // HTML template with {{placeholders}}
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  generatedLetters GeneratedLetter[]
}

model GeneratedLetter {
  id            Int       @id @default(autoincrement())
  userId        Int
  templateId    Int
  letterType    String                                   // same as template.type
  content       String                                   // rendered HTML
  generatedBy   Int                                      // admin userId
  generatedAt   DateTime  @default(now())

  user          User            @relation(fields: [userId], references: [id])
  template      LetterTemplate  @relation(fields: [templateId], references: [id])
  generatedByUser User          @relation("LetterGeneratedBy", fields: [generatedBy], references: [id])

  @@index([userId])
}

// ═══════════════════════════════════════════════
// Asset Management
// ═══════════════════════════════════════════════

model Asset {
  id             Int       @id @default(autoincrement())
  name           String                                  // "Dell Laptop", "iPhone 15"
  type           String                                  // laptop, phone, simcard, mouse, charger, monitor, keyboard, headset, id_card, access_card, scanner, ac_remote, other
  serialNumber   String?
  assetNumber    String?   @unique                       // Asset Number (was assetTag — "AST-001" office tracking number)
  assetTag       String?   @unique                       // Legacy — kept for backward compatibility
  category       String    @default("personal")          // personal (assigned to person), office (shared/office use), infrastructure
  purchaseDate   String?                                 // "YYYY-MM-DD"
  purchasePrice  Float?                                  // original purchase cost (manually entered)
  value          Float?                                  // current value (auto-calculated from depreciation)
  depreciationRate   Float?    @default(10)              // depreciation percentage (default 10%)
  depreciationPeriod String?   @default("yearly")        // yearly, monthly, quarterly
  warrantyExpiry String?                                 // "YYYY-MM-DD" — warranty end date
  warrantyVendor String?                                 // vendor/brand for warranty claims
  condition      String    @default("good")              // new, good, fair, damaged, non_working
  status         String    @default("available")         // available, assigned, maintenance, retired, lost
  assignedTo     Int?
  assignedDate   String?                                 // "YYYY-MM-DD"
  returnDate     String?                                 // "YYYY-MM-DD"

  // New fields
  brand          String?                                 // Brand name (Apple, Dell, HP, etc.)
  assetGroup     String?                                 // Grouping (IT Equipment, Furniture, Vehicle, etc.)
  description    String?                                 // Detailed description
  modelNo        String?                                 // Model number
  invoiceNo      String?                                 // Invoice number
  invoiceCopyUrl String?                                 // Google Drive URL for invoice PDF
  invoiceCopyDriveId String?                             // Google Drive file ID for invoice
  assetImages    String?                                 // JSON array of up to 6 image URLs from Google Drive
  assetImageDriveIds String?                             // JSON array of Drive file IDs for images
  assetOwner     String?                                 // "employee:userId" or "other:Name" — who owns/uses the asset
  assetOldUser   String?                                 // Previous user (free text)
  maintenanceLogs String?                                // JSON array: [{startDate, endDate, days, amount, issue, solution}]

  notes          String?
  companyId      Int?
  companyRegistrationId Int?                              // Links to CompanyRegistration (GSTIN-level ownership)
  location       String?                                  // "Miraroad", "Lucknow" — office location where asset is
  isMandatoryReturn Boolean @default(true)               // must return on exit (false for consumables)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assignee          User?     @relation("AssetAssignment", fields: [assignedTo], references: [id])
  company           Company?  @relation(fields: [companyId], references: [id])
  companyRegistration CompanyRegistration? @relation("AssetCompanyRegistration", fields: [companyRegistrationId], references: [id])
  handovers         AssetHandover[]
  repairHistory     AssetRepair[]

  // Lifecycle Management Relations
  assignments       AssetAssignment[]
  movements         AssetMovement[]
  conditionLogs     AssetConditionLog[]
  disposals         AssetDisposal[]
  detachmentRequests AssetDetachmentRequest[]
  
  // Predictive Maintenance Relations
  healthScore       AssetHealthScore?
  predictions       PredictionResult?
  recommendations   MaintenanceRecommendation[]

  @@index([assignedTo])
  @@index([status])
  @@index([category])
  @@index([type])
}

// ═══════════════════════════════════════════════
// Employee Lifecycle (Onboarding & Separation)
// ═══════════════════════════════════════════════

model OnboardingChecklist {
  id           Int       @id @default(autoincrement())
  userId       Int
  task         String                                    // "Submit ID proof", "Bank account form"
  category     String    @default("hr_formalities")      // documents, it_setup, hr_formalities, training
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  dueDate      String?                                   // "YYYY-MM-DD"
  assignedTo   String?                                   // "HR", "IT", "Manager"
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isCompleted])
}

model Separation {
  id                 Int       @id @default(autoincrement())
  userId             Int       @unique
  type               String                              // resignation, termination, absconding, retirement
  requestDate        String                              // "YYYY-MM-DD"
  lastWorkingDate    String?                             // "YYYY-MM-DD"
  reason             String?
  status             String    @default("initiated")     // initiated, notice_period, fnf_pending, completed, cancelled
  noticePeriodDays   Int       @default(30)
  exitInterviewDone  Boolean   @default(false)
  exitInterviewNotes String?
  allAssetsReturned  Boolean   @default(false)           // must be true before FnF
  assetReturnNotes   String?                             // JSON: details of pending/returned assets
  fnfAmount          Float?
  fnfHoldReason      String?                             // "pending_asset_return" etc.
  fnfPaidOn          String?                             // "YYYY-MM-DD"
  processedBy        Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User     @relation(fields: [userId], references: [id])
  processor          User?    @relation("SeparationHandler", fields: [processedBy], references: [id])
}

// ═══════════════════════════════════════════════
// Shift Management
// ═══════════════════════════════════════════════

model ShiftDefinition {
  id            Int       @id @default(autoincrement())
  name          String                                   // "General", "Morning", "Night", "Flexi"
  startTime     String                                   // "09:00"
  endTime       String                                   // "18:00"
  graceMinutes  Int       @default(15)
  isActive      Boolean   @default(true)
  companyId     Int?
  createdAt     DateTime  @default(now())

  company       Company?  @relation(fields: [companyId], references: [id])
}

// ═══════════════════════════════════════════════
// Surveys & Feedback
// ═══════════════════════════════════════════════

model Survey {
  id            Int       @id @default(autoincrement())
  title         String
  description   String?
  type          String    @default("pulse")              // pulse, engagement, exit, custom
  questions     String                                   // JSON array: [{question, type, options?}]
  isActive      Boolean   @default(true)
  isAnonymous   Boolean   @default(false)
  expiresAt     DateTime?
  companyId     Int?                                     // null = all companies
  createdBy     Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator       User      @relation("SurveyCreator", fields: [createdBy], references: [id])
  company       Company?  @relation(fields: [companyId], references: [id])
  responses     SurveyResponse[]

  @@index([isActive])
}

model SurveyResponse {
  id          Int       @id @default(autoincrement())
  surveyId    Int
  userId      Int?                                       // null if anonymous
  answers     String                                     // JSON: [{questionIndex, answer}]
  submittedAt DateTime  @default(now())

  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ═══════════════════════════════════════════════
// Helpdesk / Ticketing
// ═══════════════════════════════════════════════

model Ticket {
  id            Int       @id @default(autoincrement())
  userId        Int                                       // ticket creator
  subject       String
  description   String
  category      String    @default("hr")                  // it, hr, admin, facilities, other
  priority      String    @default("medium")              // low, medium, high, urgent
  status        String    @default("open")                // open, in_progress, resolved, closed
  assignedTo    Int?                                      // admin/support userId
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  assignee      User?     @relation("TicketAssignee", fields: [assignedTo], references: [id])
  comments      TicketComment[]

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
}

model TicketComment {
  id          Int       @id @default(autoincrement())
  ticketId    Int
  userId      Int
  content     String
  isInternal  Boolean   @default(false)                   // admin-only notes
  createdAt   DateTime  @default(now())

  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

// ═══════════════════════════════════════════════
// OTP Verification
// ═══════════════════════════════════════════════

model OtpVerification {
  id          Int       @id @default(autoincrement())
  userId      Int
  phone       String
  otp         String
  purpose     String    @default("mobile_verify")          // mobile_verify, emergency_verify
  verified    Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@index([phone, otp])
  @@index([userId])
}

// ═══════════════════════════════════════════════
// Asset Handover (Exit/Transfer tracking)
// ═══════════════════════════════════════════════

model AssetHandover {
  id            Int       @id @default(autoincrement())
  assetId       Int
  fromUserId    Int
  toUserId      Int?                                       // null = returned to office pool
  handoverType  String    @default("return")               // return, transfer, exit_return
  condition     String    @default("good")                 // good, damaged, lost
  notes         String?
  handoverDate  String                                     // "YYYY-MM-DD"
  receivedBy    Int?                                       // admin who received
  createdAt     DateTime  @default(now())

  asset         Asset     @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([fromUserId])
}

// ═══════════════════════════════════════════════
// Employee Wiki / Knowledge Base
// ═══════════════════════════════════════════════

model WikiArticle {
  id            Int       @id @default(autoincrement())
  title         String
  content       String                                     // markdown content
  category      String    @default("general")              // travel, contacts, food, emergency, office_info, general
  location      String?                                    // Miraroad, Lucknow, or null for all
  isPinned      Boolean   @default(false)
  createdBy     Int
  lastEditedBy  Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([category])
  @@index([location])
  @@index([isActive])
}

// ═══════════════════════════════════════════════
// Anonymous Suggestions
// ═══════════════════════════════════════════════

model Suggestion {
  id            Int       @id @default(autoincrement())
  content       String
  category      String    @default("general")              // general, improvement, complaint, appreciation
  userId        Int                                        // hidden from all except admin
  adminReply    String?
  status        String    @default("new")                  // new, reviewed, acknowledged, implemented
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════
// Automation Insights (Repetitive Task Detection)
// ═══════════════════════════════════════════════

model AutomationInsight {
  id                     Int      @id @default(autoincrement())
  patternName            String
  patternDescription     String?
  category               String   @default("general")           // data_entry, communication, reporting, scheduling, procurement, approval, general
  frequency              Int      @default(0)                   // total occurrences in analysis period
  frequencyPerWeek       Float    @default(0)
  totalHoursPerWeek      Float    @default(0)
  estimatedSavingsPerWeek Float   @default(0)
  affectedUsers          Json?                                  // [{id, name, department, occurrences, hoursPerWeek}]
  affectedUserCount      Int      @default(0)
  sampleTasks            Json?                                  // ["task description 1", "task description 2", ...]
  automationSuggestion   String?
  suggestedTools         Json?                                  // ["Google Apps Script", "Zapier", ...]
  priority               String   @default("medium")            // high, medium, low
  status                 String   @default("new")               // new, reviewing, will_automate, automated, dismissed
  adminNotes             String?
  analysisDate           String                                 // "YYYY-MM-DD"
  analysisPeriodDays     Int      @default(30)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([analysisDate])
  @@index([isActive])
}

model AutomationAnalysisLog {
  id              Int      @id @default(autoincrement())
  analysisDate    String                                        // "YYYY-MM-DD"
  periodDays      Int      @default(30)
  totalReports    Int      @default(0)
  totalTasks      Int      @default(0)
  totalUsers      Int      @default(0)
  clustersFound   Int      @default(0)
  insightsCreated Int      @default(0)
  aiModel         String?
  durationMs      Int?
  triggeredBy     String   @default("manual")                   // manual, cron
  triggeredByUserId Int?
  status          String   @default("running")                  // running, completed, failed
  error           String?
  createdAt       DateTime @default(now())

  @@index([analysisDate])
}




// ═══════════════════════════════════════════════
// Expense Approval History
// ═══════════════════════════════════════════════

model ExpenseApprovalLog {
  id            Int       @id @default(autoincrement())
  expenseId     Int
  action        String                                     // submitted, approved, rejected, paid
  actionBy      Int
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([expenseId])
  @@index([actionBy])
}

// ═══════════════════════════════════════════════
// Notifications
// ═══════════════════════════════════════════════

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      String    @default("info")              // wiki_update, announcement, policy, ticket, general, info
  title     String
  message   String?
  link      String?                                 // frontend route to navigate to
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── Google Drive File Management ───
model DriveFile {
  id            Int       @id @default(autoincrement())
  userId        Int
  driveFileId   String    @unique
  driveFolderId String
  fileName      String
  mimeType      String
  fileSize      Int       @default(0)
  driveUrl      String
  thumbnailUrl  String?
  category      String    @default("other")    // photo, document, receipt, id_proof, education, other
  description   String?
  uploadedAt    DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([category])
  @@index([userId, category])
}

// ─── Shift Management ───
model Shift {
  id              Int       @id @default(autoincrement())
  name            String    @unique              // "Morning", "Evening", "Night", "General"
  startTime       String                         // "09:00" format (24-hour)
  endTime         String                         // "18:00" format (24-hour)
  breakDuration   Int       @default(60)         // minutes
  flexibility     Int       @default(0)          // flexibility in minutes (e.g., 15 min early/late)
  description     String?
  isActive        Boolean   @default(true)
  companyId       Int?                           // null for company-wide shifts
  company         Company?  @relation(fields: [companyId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shiftAssignments ShiftAssignment[]

  @@index([isActive])
  @@index([companyId])
}

model ShiftAssignment {
  id                Int       @id @default(autoincrement())
  userId            Int
  shiftId           Int
  assignedAt        DateTime  @default(now())
  assignedBy        Int                          // Manager/Admin who assigned
  effectiveFrom     String?                      // "YYYY-MM-DD" when shift takes effect (future date allowed)
  effectiveTo       String?                      // "YYYY-MM-DD" when shift assignment ends
  reason            String?                      // "Promotion", "Request", "Manager Decision", etc.
  status            String    @default("active") // active, pending, expired, cancelled
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation("ShiftAssignments", fields: [userId], references: [id])
  shift             Shift     @relation(fields: [shiftId], references: [id])
  assignedByUser    User      @relation("ShiftAssignmentsCreatedBy", fields: [assignedBy], references: [id])

  @@unique([userId, shiftId, effectiveFrom])
  @@index([userId])
  @@index([shiftId])
  @@index([status])
  @@index([effectiveFrom])
}

// ═══════════════════════════════════════════════
// Asset Repair & Maintenance Tracking
// ═══════════════════════════════════════════════

model AssetRepair {
  id                Int       @id @default(autoincrement())
  assetId           Int
  repairType        String                              // "maintenance", "repair", "inspection", "calibration"
  status            String    @default("initiated")     // initiated, in_transit, in_progress, ready_for_pickup, completed, cancelled
  sentOutDate       String                              // "YYYY-MM-DD" when asset left office
  expectedReturnDate String                             // "YYYY-MM-DD" expected return date
  actualReturnDate  String?                             // "YYYY-MM-DD" actual return date (null until completed)
  daysOverdue       Int?      @default(0)               // calculated: max(0, today - expectedReturnDate)
  vendor            String?                             // repair vendor/service center name
  vendorPhone       String?                             // contact phone
  vendorEmail       String?                             // contact email
  vendorLocation    String?                             // where asset was sent (location/city)
  estimatedCost     Float?                              // estimated repair cost
  actualCost        Float?                              // actual repair cost
  invoiceNumber     String?                             // vendor invoice/reference number
  notes             String?                             // detailed notes about repair
  issueDescription  String?                             // what was wrong with the asset
  initiatedBy       Int                                 // user ID who marked asset for repair
  completedBy       Int?                                // user ID who confirmed return
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  asset             Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  initiator         User      @relation("RepairInitiator", fields: [initiatedBy], references: [id])
  completer         User?     @relation("RepairCompleter", fields: [completedBy], references: [id])
  timeline          RepairTimeline[]

  @@index([assetId])
  @@index([status])
  @@index([sentOutDate])
  @@index([expectedReturnDate])
  @@index([initiatedBy])
}

model RepairTimeline {
  id          Int       @id @default(autoincrement())
  repairId    Int
  oldStatus   String                                    // previous status
  newStatus   String                                    // new status
  changedBy   Int                                       // user ID who made the change
  notes       String?                                   // optional notes about the change
  changedAt   DateTime  @default(now())

  repair      AssetRepair @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([repairId])
  @@index([changedAt])
}

// ─── Insurance Card Management ───
model InsuranceCard {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique                          // One active insurance card per employee
  cardType      String    @default("health")             // health, life, accidental, other
  fileUrl       String                                     // URL to PDF or image (Vercel Blob or Drive)
  fileName      String                                     // Original filename for download
  mimeType      String                                     // application/pdf, image/png, image/jpeg
  fileSize      Int       @default(0)                      // bytes
  uploadedBy    Int                                        // Admin/HR who uploaded
  uploadedAt    DateTime  @default(now())
  effectiveFrom String?                                    // "YYYY-MM-DD" when card becomes effective
  effectiveTo   String?                                    // "YYYY-MM-DD" when card expires
  providerName  String?                                    // Insurance provider ("ICICI Prudential", etc.)
  policyNumber  String?                                    // Insurance policy number
  coverageAmount Float?                                    // Coverage amount in INR
  notifiedAt    DateTime?                                  // When user was notified about new card
  isViewed      Boolean   @default(false)                  // Has user viewed the card?
  viewedAt      DateTime?                                  // When user first viewed the card
  notes         String?                                    // Admin notes about the card
  isActive      Boolean   @default(true)                   // Is this the current active card?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  uploader      User      @relation("InsuranceCardsUploaded", fields: [uploadedBy], references: [id])

  @@index([userId])
  @@index([isActive])
  @@index([uploadedAt])
  @@index([effectiveFrom])
}

// ═══════════════════════════════════════════════════════════════════════════════════
// ASSET LIFECYCLE MANAGEMENT SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════════
// Complete end-to-end asset tracking from purchase → assignment → repair/disposal
// Phase 1 Models: Core lifecycle management

// ─── Location / Warehouse Management ───
model Location {
  id              Int       @id @default(autoincrement())
  name            String                                  // "Warehouse A", "Miraroad Office Floor 2", "Lucknow Office"
  type            String    @default("warehouse")         // warehouse, office, desk, storage
  address         String?
  city            String?
  state           String?
  pincode         String?
  inchargeUserId  Int?                                    // Person responsible for this location
  companyId       Int?
  latitude        Float?
  longitude       Float?
  capacity        Int?                                    // Total asset capacity (if warehouse)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         Company?  @relation(fields: [companyId], references: [id])
  incharge        User?     @relation("LocationIncharge", fields: [inchargeUserId], references: [id])
  movementsFrom   AssetMovement[] @relation("AssetMovementFrom")
  movementsTo     AssetMovement[] @relation("AssetMovementTo")

  @@index([type])
  @@index([isActive])
  @@index([city])
}

// ─── Asset Assignment Tracking (enhanced) ───
model AssetAssignment {
  id              Int       @id @default(autoincrement())
  assetId         Int
  userId          Int
  assignmentDate  String                                  // "YYYY-MM-DD"
  returnDate      String?                                 // "YYYY-MM-DD" (null = still assigned)
  assignmentReason String?                               // "New hire", "Replacement", "Upgrade"
  status          String    @default("assigned")          // assigned, returned, pending_return
  assignedBy      Int
  returnedBy      Int?
  condition       String?                                 // Condition when returned (good, damaged, etc.)
  returnNotes     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignee        User      @relation("AssetAssignee", fields: [userId], references: [id])
  assigner        User      @relation("AssignmentCreator", fields: [assignedBy], references: [id])
  returner        User?     @relation("AssignmentReturner", fields: [returnedBy], references: [id])

  @@unique([assetId, userId, assignmentDate])
  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@index([assignmentDate])
}

// ─── Asset Movement Tracking ───
model AssetMovement {
  id              Int       @id @default(autoincrement())
  assetId         Int
  fromLocation    Int?                                    // null = incoming stock
  toLocation      Int
  movementType    String    @default("transfer")          // transfer, stock_in, stock_out, assignment, return, repair_out, repair_in
  movementDate    String                                  // "YYYY-MM-DD"
  movementTime    String?                                 // "HH:MM:SS"
  reason          String?                                 // "Repair", "Office transfer", "Employee relocation"
  movedBy         Int
  quantity        Int       @default(1)
  barcode         String?                                 // QR/Barcode for tracking
  notes           String?
  createdAt       DateTime  @default(now())

  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  from            Location? @relation("AssetMovementFrom", fields: [fromLocation], references: [id])
  to              Location  @relation("AssetMovementTo", fields: [toLocation], references: [id])
  movedByUser     User      @relation(fields: [movedBy], references: [id])

  @@index([assetId])
  @@index([movementDate])
  @@index([movementType])
  @@index([toLocation])
}

// ─── Asset Condition Logging ───
model AssetConditionLog {
  id              Int       @id @default(autoincrement())
  assetId         Int
  previousCondition String
  newCondition    String                                  // new, good, fair, damaged, non_working, beyond_repair
  checkedBy       Int
  checkDate       String                                  // "YYYY-MM-DD"
  notes           String?
  photosUrl       String?                                 // JSON array of photo URLs if damages
  requiresRepair  Boolean   @default(false)
  createdAt       DateTime  @default(now())

  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  checker         User      @relation(fields: [checkedBy], references: [id])

  @@index([assetId])
  @@index([checkDate])
  @@index([newCondition])
}

// ─── Asset Disposal / Scrapping ───
model AssetDisposal {
  id              Int       @id @default(autoincrement())
  assetId         Int
  disposalType    String                                  // scrap, salvage, donation, resale, return_to_vendor
  disposalReason  String?
  disposalDate    String                                  // "YYYY-MM-DD"
  approvalStatus  String    @default("pending")           // pending, approved, rejected, completed
  approvedBy      Int?
  approvalDate    DateTime?
  recoveryValue   Float?                                  // Amount recovered from resale/salvage
  recoveryVendor  String?                                 // Vendor who took the asset
  notes           String?
  certificateUrl  String?                                 // URL to disposal certificate if required
  createdBy       Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  approver        User?     @relation("DisposalApprover", fields: [approvedBy], references: [id])
  creator         User      @relation("DisposalCreator", fields: [createdBy], references: [id])

  @@index([assetId])
  @@index([disposalDate])
  @@index([disposalType])
  @@index([approvalStatus])
}

// ─── Asset Detachment Request (Employee self-request) ───
model AssetDetachmentRequest {
  id              Int       @id @default(autoincrement())
  assetId         Int
  userId          Int
  requestDate     String                                  // "YYYY-MM-DD"
  reason          String                                  // "Damaged", "Lost", "Not in use", "Replacement needed"
  description     String?
  requestStatus   String    @default("pending")           // pending, approved, rejected
  postApprovalAction String?                              // repair, scrap, return, custody (selected after approval)
  approvedBy      Int?
  approvalDate    DateTime?
  approvalNotes   String?
  actionCompletedDate String? // "YYYY-MM-DD" - when post-approval action (repair/scrap/custody) was completed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requester       User      @relation("DetachmentRequester", fields: [userId], references: [id])
  approver        User?     @relation("DetachmentApprover", fields: [approvedBy], references: [id])

  @@index([assetId])
  @@index([userId])
  @@index([requestStatus])
  @@index([requestDate])
  @@index([postApprovalAction])
}

// ═══════════════════════════════════════════════
// Predictive Maintenance & ML Integration
// ═══════════════════════════════════════════════

model AssetHealthScore {
  id                    Int       @id @default(autoincrement())
  assetId               Int       @unique
  
  // Health Components (0-100 each)
  ageScore              Float     @default(0)            // Based on asset age
  usageIntensityScore   Float     @default(0)            // Based on repair frequency
  repairHistoryScore    Float     @default(0)            // Based on repair quality
  turnaroundScore       Float     @default(0)            // Based on vendor performance
  
  // Aggregate Scores
  overallHealthScore    Float     @default(0)            // 0-100 weighted average
  riskLevel             String    @default("low")        // low/medium/high/critical
  healthTrend           String    @default("stable")     // improving/stable/declining
  lastUpdated           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  asset                 Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  @@index([assetId])
  @@index([overallHealthScore])
  @@index([riskLevel])
}

model PredictionResult {
  id                    Int       @id @default(autoincrement())
  assetId               Int       @unique
  
  // Failure Prediction (0-100 probability)
  failureProb30Days     Float     @default(0)            // Next 30 days
  failureProb60Days     Float     @default(0)            // Next 60 days
  failureProb90Days     Float     @default(0)            // Next 90 days
  
  // Confidence & Reasoning
  confidenceScore       Float     @default(0)            // 0-100
  primaryRiskFactors    String    @default("[]")         // JSON array of top 3 risk factors
  riskDescription       String?                          // Human-readable explanation
  
  // Prediction Metadata
  modelVersion          String    @default("v1.0")       // e.g., "v1.0"
  predictionDate        DateTime  @default(now())
  lastRecalculated      DateTime  @updatedAt
  
  asset                 Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  @@index([assetId])
  @@index([failureProb30Days])
  @@index([predictionDate])
}

model MaintenanceRecommendation {
  id                    Int       @id @default(autoincrement())
  assetId               Int
  
  // Recommendation Details
  action                String                          // "preventive_maintenance", "inspection", "parts_replacement", etc.
  urgency               String    @default("medium")    // "low", "medium", "high", "critical"
  priority              Int       @default(50)          // 1-100 for ranking
  
  // Impact Metrics
  estimatedCost         Float?
  estimatedDowntime     Int?                            // hours
  failureRiskReduction  Float?                          // % reduction if action taken
  estimatedROI          Float?                          // cost savings / action cost
  
  // Recommendation Reasoning
  reasoning             String?                         // Why this recommendation
  confidenceScore       Float     @default(0)           // 0-100
  suggestedVendor       String?                         // Recommended vendor if applicable
  
  // Status Tracking
  status                String    @default("pending")   // pending/approved/in_progress/completed
  approvedBy            Int?
  approvedAt            DateTime?
  completedAt           DateTime?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  asset                 Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  approver              User?     @relation("MaintenanceApprover", fields: [approvedBy], references: [id])
  
  @@index([assetId])
  @@index([urgency])
  @@index([priority])
  @@index([status])
}

// ─── Error Reporting ─────────────────────────────────────────────────────────
// Captures frontend JS errors and failed API calls; gives admin
// an AI-powered "Fix It" action to diagnose and resolve issues.

model ErrorReport {
  id           Int      @id @default(autoincrement())

  // Deduplication: SHA-256 of (errorType + "|" + path + "|" + errorMessage)
  // Duplicate submissions increment occurrenceCount; no new record is created.
  fingerprint      String   @unique
  occurrenceCount  Int      @default(1)   // how many times this exact error was reported
  lastOccurredAt   DateTime @default(now())
  affectedUsers    String?  // JSON array of { userId, userEmail, userName, reportedAt }

  // First reporter (null if unauthenticated)
  userId       Int?
  userEmail    String?
  userName     String?

  // Where / what
  errorType    String   @default("client") // "client" | "api"
  path         String                      // URL path where the error occurred
  method       String?                     // HTTP method for API errors
  statusCode   Int?                        // HTTP status code (for API errors)
  errorMessage String                      // Primary error message

  // Debug details
  stackTrace   String?                     // JS stack trace or server stack
  context      String?                     // JSON string of extra context (props, params, body)
  componentStack String?                   // React component stack (for JS errors)

  // Resolution
  status       String   @default("new")    // "new" | "reviewing" | "fixed" | "dismissed"
  aiAnalysis   String?                     // AI diagnosis result (JSON string)
  aiModel      String?                     // Which AI model performed the analysis/fix
  resolution   String?                     // How it was resolved (human note or AI fix result)
  resolvedAt   DateTime?
  resolvedBy   Int?

  createdAt    DateTime @default(now())

  reporter     User?    @relation("ErrorReporter", fields: [userId], references: [id], onDelete: SetNull)
  resolver     User?    @relation("ErrorResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@index([errorType])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════
// Branch Management (Multi-Branch Holiday Support)
// ═══════════════════════════════════════════════

model Branch {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  label     String?                              // display label: "Mumbai HQ", "Lucknow", "E-APOB"
  state     String
  city      String
  address   String?
  companyId Int?                                  // optional link to Company
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company   Company?  @relation(fields: [companyId], references: [id])
  users     User[]
  holidays  BranchHoliday[]
}

model BranchHoliday {
  id         Int     @id @default(autoincrement())
  branchId   Int
  name       String
  date       String  // "YYYY-MM-DD"
  year       Int
  isOptional Boolean @default(false)

  branch     Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([branchId, year])
}

// ═══════════════════════════════════════════════
// Confirmation Extension Audit Log
// ═══════════════════════════════════════════════

model ConfirmationExtension {
  id               Int      @id @default(autoincrement())
  userId           Int
  extendedBy       Int
  previousDueDate  String   // "YYYY-MM-DD"
  newDueDate       String   // "YYYY-MM-DD"
  reason           String?
  createdAt        DateTime @default(now())

  user             User     @relation("ConfirmationExtensions", fields: [userId], references: [id], onDelete: Cascade)
  extender         User     @relation("ConfirmationExtensionsBy", fields: [extendedBy], references: [id])

  @@index([userId])
}

// ═══════════════════════════════════════════════
// Company Contracts (Software Licenses, Services,
// Compliance, IP Assets, Misc)
// ═══════════════════════════════════════════════

model CompanyContract {
  id               Int      @id @default(autoincrement())
  companyId        Int?

  // ── Classification ──
  // category: software | service | compliance | ip | misc
  category         String
  // subCategory examples:
  //   software  → tally, windows_license, aws, github, gsuite, other
  //   service   → pest_control, water_filter, ac_maintenance, cctv, internet, other
  //   compliance→ fssai, fire_safety, gst_filing, other
  //   ip        → trademark, patent, copyright, other
  //   misc      → harwala, fish_tank, activa, other
  subCategory      String?

  // ── Basic Info ──
  name             String                     // "Tally Prime", "FSSAI License 2026"
  description      String?
  status           String   @default("active") // active, expired, pending, cancelled, renewed

  // ── Vendor Info ──
  vendorName       String?
  vendorContact    String?                    // phone or email
  vendorPAN        String?
  vendorGST        String?

  // ── Payment / Finance ──
  amount           Float?                     // cost in INR
  paymentMode      String?                    // cash, upi, bank_transfer, cheque, neft, rtgs
  paymentDate      String?                    // "YYYY-MM-DD"
  paymentUTR       String?                    // UTR / cheque number
  vendorBankName   String?
  vendorBankAccount String?
  vendorIfsc       String?

  // ── Invoice ──
  invoiceNumber    String?
  invoiceDate      String?                    // "YYYY-MM-DD"
  invoiceFileUrl   String?                    // Google Drive URL

  // ── Dates ──
  startDate        String?                    // "YYYY-MM-DD"
  expiryDate       String?                    // "YYYY-MM-DD" – drives expiry alerts
  renewalDate      String?                    // "YYYY-MM-DD" – when to action renewal
  lastServiceDate  String?                    // "YYYY-MM-DD" – last serviced/paid

  // ── Software-specific ──
  licenseKey       String?
  seats            Int?                       // number of users/seats

  // ── IP-specific ──
  registrationNumber String?
  ipClass          String?                    // e.g. "Class 16" for trademark
  ipJurisdiction   String?                    // India, USA, etc.

  // ── Audit ──
  notes            String?
  createdBy        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ── Signing Workflow ──
  signingStatus           String?  @default("none")    // none, draft, sent, partially_signed, fully_signed, expired, cancelled
  signingToken            String?  @unique             // crypto.randomUUID()
  signingTokenExpiresAt   String?                      // "YYYY-MM-DD"

  externalSignerName      String?
  externalSignerEmail     String?
  externalSignerPhone     String?

  internalSignerId        Int?

  contractFileUrl         String?
  contractDriveFileId     String?
  signedFileUrl           String?
  signedDriveFileId       String?
  counterSignedFileUrl    String?
  counterSignedDriveFileId String?

  sentAt                  String?                      // "YYYY-MM-DD HH:mm"
  externalSignedAt        String?
  counterSignedAt         String?
  completedAt             String?
  cancelledAt             String?
  cancellationReason      String?

  templateId              Int?
  templateContent         String?                      // rendered HTML snapshot at generation time

  company          Company? @relation(fields: [companyId], references: [id])
  creator          User?    @relation("ContractCreator", fields: [createdBy], references: [id])
  template         ContractTemplate? @relation("ContractFromTemplate", fields: [templateId], references: [id])
  internalSigner   User?    @relation("ContractInternalSigner", fields: [internalSignerId], references: [id])
  signingEvents    ContractSigningEvent[]

  @@index([category])
  @@index([companyId])
  @@index([status])
  @@index([expiryDate])
  @@index([signingStatus])
  @@index([signingToken])
}

// ─── Biometric Integration ────────────────────────────────────────────────────

model BiometricDevice {
  id              Int      @id @default(autoincrement())
  name            String                              // "Main Entrance", "Server Room"
  serialNumber    String   @unique                   // Device serial number
  location        String?                             // Physical location description
  ipAddress       String?                             // Device IP for direct comm
  esslUrl         String?                             // eSSL server URL (e.g. http://192.168.2.222:85)
  apiUser         String?                             // eSSL API username
  apiPassword     String?                             // eSSL API password
  apiKey          String?                             // eSSL API key
  companyCode     String?                             // eSSL company code
  isActive        Boolean  @default(true)
  lastSyncAt      DateTime?                           // Last successful sync timestamp
  lastSyncStatus  String?                             // "success" | "failed" | "partial"
  lastSyncMessage String?                             // Error or summary message
  syncIntervalMin Int      @default(5)               // How often to poll (minutes)
  forceDirection  String?                             // null = auto-detect | "in" = always entry | "out" = always exit
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  punches         BiometricPunch[]

  @@index([serialNumber])
  @@index([isActive])
}

model BiometricPunch {
  id              Int      @id @default(autoincrement())
  deviceId        Int
  deviceSerial    String                              // Device serial (denormalised for speed)
  enrollNumber    String                              // Raw enroll/employee code from device
  punchTime       String                              // "YYYY-MM-DD HH:MM:SS"
  punchDate       String                              // "YYYY-MM-DD" (extracted for filtering)
  direction       String?                             // "in" | "out" | "unknown"
  workCode        String?                             // Optional work code from device
  rawData         String?                             // Full raw JSON payload for debugging

  // Matching result
  userId          Int?                                // NULL = unmatched / unknown employee
  matchStatus     String   @default("unmatched")     // "matched" | "unmatched" | "ignored"
  matchNote       String?                             // e.g. "No employee with bioDeviceId=XYZ"

  // Attendance linkage
  attendanceId    Int?                                // Attendance record created/updated
  processStatus   String   @default("pending")        // "pending" | "processed" | "skipped"
  processNote     String?                             // e.g. "Clock-in created" or "Duplicate"

  createdAt       DateTime @default(now())

  device          BiometricDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee        User?           @relation("PunchEmployee", fields: [userId], references: [id])

  @@unique([deviceSerial, enrollNumber, punchTime])   // Prevent duplicate punches
  @@index([deviceId])
  @@index([punchDate])
  @@index([enrollNumber])
  @@index([matchStatus])
  @@index([processStatus])
  @@index([userId])
}

// ═══════════════════════════════════════════════
// Company Master — Single Source of Truth
// ═══════════════════════════════════════════════

model LegalEntity {
  id        Int      @id @default(autoincrement())
  legalName String   // "Color Papers India Pvt. Ltd."
  shortName String?  // Company abbreviation: "CPIPL", "Gimmick"
  pan       String?  @unique
  tan       String?  @unique
  lei       String?  // Legal Entity Identifier (yearly renewal)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations CompanyRegistration[]
}

model CompanyRegistration {
  id             Int     @id @default(autoincrement())
  legalEntityId  Int
  abbr           String  @unique // e.g. "CPIPL-MUM/27-R1" — auto-computed on save
  officeCity     String  // operational city
  gstin          String  @unique // 15-char, PRIMARY identifier
  state          String
  district       String?
  stateCode      String  // gstin[0:1] as "09" (preserve leading zero)
  regNo          Int     // gstin[12] as integer
  placeType      String  @default("Principal") // Comma-separated: "Principal", "E-APOB", "I-APOB"
  address        String? // full registered address
  fssai          String? // FSSAI licence number
  udyam          String? // Udyam registration number
  iec            String? // Import Export Code
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  legalEntity    LegalEntity @relation(fields: [legalEntityId], references: [id])
  users          User[]      @relation("UserCompanyRegistration")
  assets         Asset[]     @relation("AssetCompanyRegistration")
  certificates   ComplianceCertificate[]

  @@index([legalEntityId])
  @@index([stateCode])
  @@index([isActive])
}

model ComplianceCertificate {
  id                     Int      @id @default(autoincrement())
  companyRegistrationId  Int
  certificateType        String   // FSSAI | IEC | UDYAM | GST | TAN | PAN | LEI | OTHER
  certificateNo          String
  issueDate              String?  // YYYY-MM-DD
  expiryDate             String?  // NULL if lifetime
  renewalFrequency       String   // YEARLY | 5_YEARLY | LIFETIME | NONE
  lastRenewed            String?
  nextDue                String?  // computed: lastRenewed + renewalFrequency
  reminderDays           Int      @default(30)
  documentUrl            String?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  companyRegistration    CompanyRegistration @relation(fields: [companyRegistrationId], references: [id], onDelete: Cascade)

  @@index([companyRegistrationId])
  @@index([expiryDate])
  @@index([certificateType])
}

model EntityCode {
  id         Int    @id @default(autoincrement())
  legalName  String @unique // "Color Papers India Pvt. Ltd."
  code       String @unique // "CPIPL"
}

model CityCode {
  id       Int    @id @default(autoincrement())
  cityName String @unique // "Mumbai"
  code     String @unique // "MUM"
}

// --- Renewals & Expense Control Center ----------------------------------------

model RenewalCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique  // "Software & AI", "Domains & SSL", etc.
  icon      String?           // emoji or lucide icon name
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  renewals  Renewal[]
}

model PaymentAccount {
  id          Int      @id @default(autoincrement())
  accountCode String   @unique  // CC-01, NB-01, CASH-01
  type        String            // credit_card | net_banking | cash
  name        String            // "HDFC Corporate Card"
  identifier  String?           // masked last 4 digits or account suffix
  company     String?           // which company this account belongs to
  currency    String   @default("INR")  // INR | USD
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  renewals    Renewal[]
  statements  MonthlyStatement[]
}

model Renewal {
  id               Int      @id @default(autoincrement())
  categoryId       Int?
  itemName         String
  vendorName       String?
  assignedTo       String?  // responsible person name / email

  // Login credentials
  loginUrl         String?
  loginUsername    String?
  loginPassword    String?  // stored as-is (AES encryption optional future)
  accountNumber    String?

  // Dates & billing
  startDate        String?  // YYYY-MM-DD
  renewalDate      String?  // YYYY-MM-DD � next due date
  billingCycle     String   @default("yearly")  // monthly|quarterly|half_yearly|yearly|one_time

  // Finance
  amount           Float?
  currency         String   @default("INR")  // INR | USD
  paymentMedium    String?  // credit_card | net_banking | cash
  paymentAccountId Int?
  referenceNumber  String?

  // Alerts
  alertDaysBefore  Int      @default(15)
  alertRecipients  String?  // CSV: "CEO,Accounts,IT"

  // Documents & notes
  documentPath     String?  // Drive URL
  notes            String?

  // State
  status           String   @default("active")   // active|expired|cancelled|on_hold
  reconciled       String   @default("pending")  // yes|no|pending
  reconciledDate   String?
  lastRenewedDate  String?
  lastPaidAmount   Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category         RenewalCategory? @relation(fields: [categoryId], references: [id])
  paymentAccount   PaymentAccount?  @relation(fields: [paymentAccountId], references: [id])
  history          RenewalHistory[]
  emailScans       EmailRenewalScan[]

  @@index([categoryId])
  @@index([renewalDate])
  @@index([status])
  @@index([paymentAccountId])
}

model MonthlyStatement {
  id               Int      @id @default(autoincrement())
  month            String            // "2026-03"
  paymentAccountId Int
  filePath         String?           // Drive URL
  uploadedBy       Int
  uploadedAt       DateTime @default(now())
  status           String   @default("uploaded")  // uploaded|processing|done
  notes            String?

  paymentAccount   PaymentAccount @relation(fields: [paymentAccountId], references: [id])
  uploader         User           @relation("StatementUploader", fields: [uploadedBy], references: [id])

  @@index([paymentAccountId])
  @@index([month])
}

model RenewalHistory {
  id          Int      @id @default(autoincrement())
  renewalId   Int
  action      String   // created|updated|paid|renewed|reconciled|locked
  oldValue    String?
  newValue    String?
  performedBy Int
  createdAt   DateTime @default(now())

  renewal     Renewal @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  performer   User    @relation("RenewalHistoryPerformer", fields: [performedBy], references: [id])

  @@index([renewalId])
}

model EmailRenewalScan {
  id              Int      @id @default(autoincrement())
  gmailMessageId  String   @unique   // Gmail message ID — dedup key
  subject         String
  sender          String
  receivedAt      DateTime
  extractedData   String   // JSON: { vendor, amount, renewalDate, itemName, confidence }
  status          String   @default("pending")  // pending | linked | dismissed
  renewalId       Int?     // linked renewal if accepted
  reviewedBy      Int?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())

  renewal  Renewal? @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  reviewer User?    @relation("EmailScanReviewer", fields: [reviewedBy], references: [id])

  @@index([status])
  @@index([receivedAt])
}


// ════════════════════════════════════════════════════════════════
// CompOff / Compensatory Off
// ════════════════════════════════════════════════════════════════

model CompOffBalance {
  id        Int      @id @default(autoincrement())
  userId    Int
  year      Int
  earned    Float    @default(0)   // total days earned this year
  used      Float    @default(0)   // days consumed
  balance   Float    @default(0)   // earned - used
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([userId])
}

model CompOffRequest {
  id          Int       @id @default(autoincrement())
  userId      Int
  type        String                  // earn | redeem
  workDate    String                  // date worked (earn) or date to use (redeem)
  days        Float     @default(1)  // 0.5 or 1
  reason      String?
  status      String    @default("pending")  // pending | approved | rejected
  reviewedBy  Int?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  reviewer    User?     @relation("CompOffReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
}

// ════════════════════════════════════════════════════════════════
// Attendance Regularization
// ════════════════════════════════════════════════════════════════

model AttendanceRegularization {
  id            Int       @id @default(autoincrement())
  userId        Int
  date          String                              // "YYYY-MM-DD"
  requestedIn   String?                             // "HH:MM"
  requestedOut  String?                             // "HH:MM"
  reason        String
  status        String    @default("pending")       // pending | approved | rejected
  reviewedBy    Int?
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  reviewer      User?     @relation("RegularizationReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([date])
  @@index([status])
}

// ════════════════════════════════════════════════════════════════
// Recruitment Module
// ════════════════════════════════════════════════════════════════

model JobOpening {
  id              Int       @id @default(autoincrement())
  title           String
  department      String
  location        String?
  type            String    @default("full_time")         // full_time | part_time | contract | intern
  vacancies       Int       @default(1)
  minExperience   Float     @default(0)
  maxExperience   Float?
  minSalary       Float?
  maxSalary       Float?
  description     String?
  requirements    String?
  status          String    @default("open")              // draft | open | on_hold | closed | cancelled
  priority        String    @default("medium")            // low | medium | high | urgent
  targetDate      String?                                 // "YYYY-MM-DD"
  postedBy        Int
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  poster          User      @relation("JobPoster", fields: [postedBy], references: [id])
  candidates      Candidate[]

  @@index([status])
  @@index([department])
}

model Candidate {
  id               Int       @id @default(autoincrement())
  jobOpeningId     Int
  name             String
  email            String
  phone            String?
  currentCompany   String?
  currentDesig     String?
  currentCTC       Float?
  expectedCTC      Float?
  experienceYears  Float?
  noticePeriodDays Int?
  resumeUrl        String?
  source           String    @default("direct")           // direct | referral | linkedin | naukri | other
  referredBy       Int?
  stage            String    @default("applied")          // applied | shortlisted | interview | offered | joined | rejected | withdrawn
  rejectionReason  String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  jobOpening       JobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  referrer         User?     @relation("CandidateReferral", fields: [referredBy], references: [id])
  interviews       Interview[]
  offers           JobOffer[]

  @@index([jobOpeningId])
  @@index([stage])
  @@index([email])
}

model Interview {
  id            Int       @id @default(autoincrement())
  candidateId   Int
  round         Int       @default(1)
  type          String    @default("technical")           // technical | hr | managerial | final
  scheduledAt   DateTime
  durationMins  Int       @default(60)
  interviewers  String?                                   // JSON: [userId, ...]
  mode          String    @default("video")               // video | phone | in_person
  meetLink      String?
  venue         String?
  feedback      String?
  rating        Int?                                      // 1-5
  result        String?                                   // pass | fail | on_hold
  conductedBy   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  conductor     User?     @relation("InterviewConductor", fields: [conductedBy], references: [id])

  @@index([candidateId])
  @@index([scheduledAt])
}

model JobOffer {
  id              Int       @id @default(autoincrement())
  candidateId     Int
  jobOpeningId    Int?
  ctcOffered      Float
  joiningDate     String?                                 // "YYYY-MM-DD"
  offerLetterUrl  String?
  status          String    @default("pending")           // pending | accepted | declined | expired | revoked
  validTill       String?                                 // "YYYY-MM-DD"
  declineReason   String?
  notes           String?
  generatedBy     Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  generator       User      @relation("OfferGenerator", fields: [generatedBy], references: [id])

  @@index([candidateId])
  @@index([status])
}

// ─── Contract Templates & Signing ─────────────────────────────────────────────

model ContractTemplate {
  id          Int      @id @default(autoincrement())
  name        String                                     // "Standard NDA", "Vendor Service Agreement"
  type        String                                     // nda, service_agreement, vendor_contract, custom
  content     String                                     // HTML template with {{placeholders}}
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User?             @relation("ContractTemplateCreator", fields: [createdBy], references: [id])
  contracts   CompanyContract[] @relation("ContractFromTemplate")
}

model ContractSigningEvent {
  id            Int      @id @default(autoincrement())
  contractId    Int
  eventType     String   // created, sent, viewed, downloaded, external_signed, counter_signed, completed, cancelled, resent, expired, reminder_sent
  performedBy   String?  // user name or "External: vendor@email.com"
  performedById Int?     // User.id if internal action
  ipAddress     String?
  userAgent     String?
  notes         String?
  createdAt     DateTime @default(now())

  contract      CompanyContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}
model MonthlyLedger {
  id              Int       @id @default(autoincrement())
  userId          Int
  month           String                    // "YYYY-MM"
  openingBalance  Float     @default(0)
  closingBalance  Float     @default(0)
  totalIn         Float     @default(0)
  totalOut        Float     @default(0)
  entries         String?                   // JSON snapshot of all entries
  isLocked        Boolean   @default(false)
  lockedBy        Int?
  lockedAt        DateTime?
  generatedAt     DateTime  @default(now())
  generatedBy     Int?
  notes           String?

  user            User      @relation("MonthlyLedgers", fields: [userId], references: [id])
  lockedByUser    User?     @relation("LedgerLockedBy", fields: [lockedBy], references: [id])
  generatedByUser User?     @relation("LedgerGeneratedBy", fields: [generatedBy], references: [id])

  @@unique([userId, month])
}

model LedgerAdjustment {
  id          Int      @id @default(autoincrement())
  userId      Int
  month       String                    // "YYYY-MM"
  description String
  amount      Float                     // positive = money in, negative = money out
  date        String                    // "YYYY-MM-DD"
  createdBy   Int
  createdAt   DateTime @default(now())

  user        User     @relation("LedgerAdjustments", fields: [userId], references: [id])
  creator     User     @relation("LedgerAdjustmentCreator", fields: [createdBy], references: [id])
}
