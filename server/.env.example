# ============================================
#  CPIPL Activity Report — Environment Variables
#  Copy this file to .env and fill in your values
# ============================================

# --- DATABASE (Neon PostgreSQL) ---
# Get from: https://neon.tech → Project → Connection Details
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST-DIRECT/DATABASE?sslmode=require

# --- SERVER ---
PORT=5000
JWT_SECRET=generate-a-random-32-char-string-here

# --- AUTH (Clerk) ---
# Get from: https://clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# --- EMAIL (Gmail SMTP) ---
# Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
TEAM_LEAD_EMAIL=admin@yourcompany.com

# --- REMINDER SCHEDULE (24-hour format) ---
REMINDER_TIME_HOUR=21
REMINDER_TIME_MINUTE=0
ESCALATION_TIME_HOUR=11
ESCALATION_TIME_MINUTE=0

# --- GOOGLE OAUTH2 (User-level: Calendar, Tasks, Gmail) ---
# Get from: https://console.cloud.google.com → APIs & Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google/callback

# --- GOOGLE SERVICE ACCOUNT (Admin-level: Drive, Workspace) ---
# Local: path to JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
# Vercel: paste entire JSON content (use GOOGLE_SERVICE_ACCOUNT_KEY instead of _PATH)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GOOGLE_ADMIN_EMAIL=admin@yourcompany.com
GOOGLE_WORKSPACE_DOMAIN=yourcompany.com

# --- AI SERVICES (Optional) ---
# Requesty.ai (primary AI gateway): https://requesty.ai
REQUESTY_API_KEY=your-requesty-key
# Gemini key is stored in Settings DB, not here

# --- OLLAMA LOCAL AI (Optional, disabled by default) ---
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_CODING_MODEL=codellama
OLLAMA_EXTRACTION_MODEL=llama3
OLLAMA_FALLBACK_TO_GEMINI=true
OLLAMA_DEBUG=false

# --- BIOMETRIC SYNC (Optional) ---
BIOMETRIC_AGENT_KEY=your-biometric-agent-key
